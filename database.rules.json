{
    "rules": {
        "plataforma_estudiantes": {
            "admins": {
                "$uid": {
                    ".read": "auth != null && auth.uid === $uid"
                },
                ".write": false
            },
            "docentes": {
                ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
                ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
                "$uid": {
                    ".read": "auth != null && auth.uid === $uid"
                }
            },
            "estudiantes": {
                ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
                "$uid": {
                    ".read": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)",
                    ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)"
                }
            },
            "sesiones": {
                ".read": "auth != null",
                ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
            },
            "respuestas": {
                ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
                "$sesionId": {
                    "$uid": {
                        ".read": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)",
                        ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)"
                    }
                }
            },
            "resultados": {
                ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
                "$sesionId": {
                    ".read": "auth != null",
                    "$uid": {
                        ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)"
                    }
                }
            },
            "ranking": {
                ".read": "auth != null",
                "$sesionId": {
                    "$curso": {
                        "$uid": {
                            ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)"
                        }
                    }
                }
            },
            "mensajes": {
                ".read": "auth != null",
                ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
            }
        },
        "plataforma_lecturas": {
            "admins": {
                "$uid": {
                    ".read": "auth != null && auth.uid === $uid"
                },
                ".write": "auth != null && (root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_lecturas/admins').child(auth.uid).val() === true)"
            },
            "sesiones": {
                "$sesionId": {
                    ".read": "auth != null && ((root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_lecturas/admins').child(auth.uid).val() === true) || root.child('plataforma_lecturas/asignaciones').child(auth.uid).child($sesionId).val() === true)",
                    ".write": "auth != null && (root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_lecturas/admins').child(auth.uid).val() === true)"
                }
            },
            "asignaciones": {
                "$uid": {
                    ".read": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_lecturas/admins').child(auth.uid).val() === true)",
                    ".write": "auth != null && (root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_lecturas/admins').child(auth.uid).val() === true)"
                }
            },
            "respuestas": {
                "$sesionId": {
                    "$uid": {
                        ".read": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_lecturas/admins').child(auth.uid).val() === true)",
                        ".write": "auth != null && ((auth.uid === $uid && root.child('plataforma_lecturas/asignaciones').child(auth.uid).child($sesionId).val() === true) || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_lecturas/admins').child(auth.uid).val() === true)"
                    }
                }
            },
            "resultados": {
                "$sesionId": {
                    "$uid": {
                        ".read": "auth != null && ((auth.uid === $uid && root.child('plataforma_lecturas/sesiones').child($sesionId).child('resultados_visibles').val() === true) || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_lecturas/admins').child(auth.uid).val() === true)",
                        ".write": "auth != null && ((auth.uid === $uid && root.child('plataforma_lecturas/asignaciones').child(auth.uid).child($sesionId).val() === true) || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_lecturas/admins').child(auth.uid).val() === true)"
                    }
                }
            }
        }
    }
}
