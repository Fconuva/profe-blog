<script>
(function() {
  var DATE_LABELS = {
    '2026-06-06': 'Sábado 6 de junio',
    '2026-06-20': 'Sábado 20 de junio'
  };

  var form = document.getElementById('docente-creador-form');
  var submitBtn = document.getElementById('dc-submit');
  var errorBox = document.getElementById('dc-form-error');
  var successBox = document.getElementById('dc-success');
  var successTitle = document.getElementById('dc-success-title');
  var successMessage = document.getElementById('dc-success-message');
  var whatsappLink = document.getElementById('dc-whatsapp-link');
  var successRegistration = document.getElementById('dc-success-registration');
  var successEmail = document.getElementById('dc-success-email');
  var successSession = document.getElementById('dc-success-session');
  var successStatus = document.getElementById('dc-success-status');
  var successPaymentId = document.getElementById('dc-success-payment-id');

  function updateWhatsappLink(message) {
    if (!whatsappLink) return;
    whatsappLink.href = 'https://wa.me/56988138929?text=' + encodeURIComponent(message);
  }

  function mapStatusLabel(status) {
    if (status === 'approved') return 'Pagado / confirmado';
    if (status === 'pending_checkout') return 'Pendiente de pago';
    if (status === 'pending') return 'Pendiente';
    if (status === 'failure') return 'Pago rechazado';
    return status || 'Sin estado';
  }

  function setComprobanteInfo(data, fallbackDateLabel) {
    if (successRegistration) {
      successRegistration.textContent = data && data.id ? data.id : 'No disponible';
    }
    if (successEmail) {
      successEmail.textContent = data && data.email ? data.email : '-';
    }
    if (successSession) {
      successSession.textContent = data && data.selectedDateLabel ? data.selectedDateLabel : fallbackDateLabel;
    }
    if (successStatus) {
      successStatus.textContent = mapStatusLabel(data && data.status);
    }
    if (successPaymentId) {
      successPaymentId.textContent = data && data.paymentId ? String(data.paymentId) : 'No disponible aún';
    }
  }

  async function loadStatusByRegistration(registrationId, selectedDate, fallbackDateLabel) {
    if (!registrationId || !selectedDate) {
      setComprobanteInfo(null, fallbackDateLabel);
      return;
    }

    try {
      var response = await fetch('/api/docente-creador-estado', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ registrationId: registrationId, fecha: selectedDate })
      });
      var result = await response.json();
      if (!response.ok || !result.ok || !result.found) {
        setComprobanteInfo({ id: registrationId }, fallbackDateLabel);
        return;
      }
      setComprobanteInfo(result, fallbackDateLabel);
    } catch (error) {
      setComprobanteInfo({ id: registrationId }, fallbackDateLabel);
    }
  }

  async function handleReturnState() {
    var params = new URLSearchParams(window.location.search);
    var payment = params.get('payment');
    var date = params.get('date');
    var registration = params.get('registration');
    var dateLabel = DATE_LABELS[date] || 'la fecha seleccionada';

    if (!payment) return;

    if (payment === 'success' || payment === 'pending') {
      form.classList.add('hidden');
      successBox.classList.remove('hidden');
      if (payment === 'success') {
        successTitle.textContent = 'Pago recibido';
        successMessage.textContent = 'Tu pago fue enviado correctamente para ' + dateLabel + '. Si no ves confirmación por correo en unos minutos, escríbenos por WhatsApp.';
        updateWhatsappLink('Hola, ya pagué mi inscripción de Docente Creador para ' + dateLabel + '.');
      } else {
        successTitle.textContent = 'Pago pendiente';
        successMessage.textContent = 'MercadoPago dejó tu pago en estado pendiente para ' + dateLabel + '. Te recomendamos revisar tu correo o escribirnos para seguimiento.';
        updateWhatsappLink('Hola, mi pago de Docente Creador para ' + dateLabel + ' quedó pendiente y necesito seguimiento.');
      }
      await loadStatusByRegistration(registration, date, dateLabel);
      form.scrollIntoView({ behavior: 'smooth', block: 'start' });
      return;
    }

    if (payment === 'failure') {
      errorBox.textContent = 'El pago no se completó. Puedes volver a intentarlo con la misma fecha o escribirnos por WhatsApp si necesitas ayuda.';
      errorBox.classList.remove('hidden');
      form.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  if (!form) return;

  handleReturnState();

  form.addEventListener('submit', async function(event) {
    event.preventDefault();

    errorBox.classList.add('hidden');
    errorBox.textContent = '';

    var payload = {
      fecha: document.getElementById('dc-fecha').value,
      nombre: document.getElementById('dc-nombre').value.trim(),
      email: document.getElementById('dc-email').value.trim(),
      telefono: document.getElementById('dc-telefono').value.trim(),
      rol: document.getElementById('dc-rol').value,
      establecimiento: document.getElementById('dc-establecimiento').value.trim(),
      experienciaIa: document.getElementById('dc-nivel-ia').value,
      objetivo: document.getElementById('dc-objetivo').value.trim(),
      region: document.getElementById('dc-region').value.trim(),
      comuna: document.getElementById('dc-comuna').value.trim(),
      nivelEducativo: document.getElementById('dc-nivel-educativo').value,
      asignatura: document.getElementById('dc-asignatura').value.trim(),
      tipoEstablecimiento: document.getElementById('dc-tipo-establecimiento').value,
      aniosDocencia: document.getElementById('dc-anios-docencia').value,
      website: document.getElementById('dc-website').value.trim(),
      consent: document.getElementById('dc-consent').checked
    };

    if (!payload.consent) {
      errorBox.textContent = 'Debes aceptar el contacto para continuar con la reserva.';
      errorBox.classList.remove('hidden');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Generando pago...';

    try {
      var response = await fetch('/api/docente-creador-inscripcion', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      var result = await response.json();

      if (!response.ok || !result.ok) {
        throw new Error(result.error || 'No se pudo registrar la reserva. Intenta nuevamente.');
      }

      if (!result.checkoutUrl) {
        throw new Error('No se pudo generar el enlace de pago. Intenta nuevamente.');
      }

      window.location.href = result.checkoutUrl;
    } catch (error) {
      errorBox.textContent = error.message || 'No se pudo registrar la reserva.';
      errorBox.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Continuar a MercadoPago';
      return;
    }

    submitBtn.disabled = false;
    submitBtn.textContent = 'Continuar a MercadoPago';
  });
})();
</script>