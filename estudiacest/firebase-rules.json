{
  "rules": {
    "plataforma_estudiantes": {
      "admins": {
        ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        "$uid": {
          ".read": "auth != null && auth.uid === $uid"
        }
      },
      "docentes": {
        ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        "$uid": {
          ".read": "auth != null && auth.uid === $uid"
        }
      },
      "estudiantes": {
        ".read": "auth != null",
        ".indexOn": ["curso"],
        "$uid": {
          ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)"
        }
      },
      "sesiones": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
      },
      "respuestas": {
        ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        "$sesionId": {
          ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)",
            ".validate": "root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || data.child('completada').val() !== true || newData.child('completada').val() === true"
          }
        }
      },
      "resultados": {
        ".read": "auth != null",
        "$sesionId": {
          ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
          "$uid": {
            ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)"
          }
        }
      },
      "ranking": {
        ".read": "auth != null",
        "$sesionId": {
          ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
          "$curso": {
            "$uid": {
              ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)"
            }
          }
        }
      },
      "avatar": {
        ".read": "auth != null",
        "$uid": {
          ".read": "auth != null",
          ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)"
        }
      },
      "tareas": {
        ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        "$tareaId": {
          ".indexOn": ["curso", "completada", "submitted_at", "last_save"],
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)"
          }
        }
      },
      "mensajes": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
      },
      "admin_refresh": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        "all": {
          ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
        },
        "cursos": {
          "$curso": {
            ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
          }
        },
        "estudiantes": {
          "$uid": {
            ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
          }
        }
      },
      "arena": {
        "history": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "daily": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "records": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },
    "plataforma_lecturas": {
      ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
      "admins": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid"
        }
      },
      "sesiones": {
        "$sesionId": {
          ".read": "auth != null && root.child('plataforma_lecturas/asignaciones').child(auth.uid).child($sesionId).val() === true"
        }
      },
      "asignaciones": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid"
        }
      },
      "respuestas": {
        "$sesionId": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid && root.child('plataforma_lecturas/asignaciones').child(auth.uid).child($sesionId).val() === true"
          }
        }
      },
      "resultados": {
        "$sesionId": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid && root.child('plataforma_lecturas/sesiones').child($sesionId).child('resultados_visibles').val() === true",
            ".write": "auth != null && auth.uid === $uid && root.child('plataforma_lecturas/asignaciones').child(auth.uid).child($sesionId).val() === true"
          }
        }
      }
    },
    "plataforma_np": {
      "access": {
        ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        "allowedUids": {
          "$uid": {
            ".read": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)",
            ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
          }
        }
      },
      "$unitId": {
        ".read": "auth != null && (root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_np/access/allowedUids').child(auth.uid).val() === true)",
        "records": {
          ".write": "auth != null && (root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_np/access/allowedUids').child(auth.uid).val() === true)",
          "$recordId": {
            ".write": "auth != null && (root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_np/access/allowedUids').child(auth.uid).val() === true)"
          }
        },
        "config": {
          ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
        },
        "importMeta": {
          ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
        }
      }
    },
    ".read": false,
    ".write": false
  }
}