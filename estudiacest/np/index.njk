<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nota de Proceso U1</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root{
      --ink:#172033;
      --muted:#60708c;
      --paper:#f5f7fb;
      --panel:#ffffff;
      --line:#dde4ef;
      --deep:#0f3557;
      --teal:#0f766e;
      --teal-soft:#d7f4ef;
      --gold:#c98b2c;
      --gold-soft:#fff1d7;
      --rose:#9b2c2c;
      --rose-soft:#ffe3e3;
      --shadow:0 18px 45px rgba(17,24,39,.08);
      --radius:22px;
    }

    *{box-sizing:border-box}
    html,body{margin:0;padding:0}
    body{
      font-family:'Inter',system-ui,sans-serif;
      color:var(--ink);
      min-height:100vh;
      background:
        radial-gradient(circle at top left, rgba(15,118,110,.12), transparent 30%),
        radial-gradient(circle at top right, rgba(201,139,44,.14), transparent 34%),
        linear-gradient(180deg,#eef3fb 0%,#f8fafc 35%,#eff5f9 100%);
    }

    .hidden{display:none !important}

    .gate-shell{
      min-height:100vh;
      display:grid;
      place-items:center;
      padding:32px 18px;
    }

    .gate-card,
    .panel,
    .topbar{
      background:rgba(255,255,255,.88);
      backdrop-filter:blur(14px);
      border:1px solid rgba(221,228,239,.9);
      box-shadow:var(--shadow);
    }

    .gate-card{
      width:min(560px,100%);
      border-radius:30px;
      padding:30px 26px 26px;
      position:relative;
      overflow:hidden;
    }

    .gate-card::before{
      content:'';
      position:absolute;
      inset:0 0 auto 0;
      height:10px;
      background:linear-gradient(90deg,var(--teal),#1f4e79,var(--gold));
    }

    .eyebrow{
      display:inline-flex;
      align-items:center;
      gap:8px;
      font-size:11px;
      letter-spacing:.12em;
      font-weight:800;
      text-transform:uppercase;
      color:var(--teal);
      background:var(--teal-soft);
      border-radius:999px;
      padding:8px 12px;
      margin-bottom:16px;
    }

    .gate-card h1,
    .hero-copy h1{
      font-family:'Fraunces',Georgia,serif;
      font-size:clamp(2rem,3.2vw,2.6rem);
      line-height:1.05;
      margin:0 0 10px;
      letter-spacing:-.03em;
    }

    .gate-copy,
    .panel-note,
    .field-help,
    .muted,
    .meta-line{
      color:var(--muted);
      line-height:1.6;
      font-size:14px;
    }

    .field-grid{
      display:grid;
      gap:14px;
      margin:22px 0 18px;
    }

    .field label,
    .weights-grid label{
      display:block;
      font-size:11px;
      text-transform:uppercase;
      letter-spacing:.1em;
      font-weight:800;
      color:#456;
      margin-bottom:7px;
    }

    .field input,
    .field select,
    .field textarea,
    .weights-grid input{
      width:100%;
      border:1px solid #cfd8e6;
      border-radius:14px;
      background:#fff;
      padding:13px 14px;
      font:inherit;
      color:var(--ink);
      transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;
    }

    .field textarea{
      min-height:168px;
      resize:vertical;
      font-family:Consolas,'Courier New',monospace;
      font-size:13px;
      line-height:1.55;
    }

    .field input:focus,
    .field select:focus,
    .field textarea:focus,
    .weights-grid input:focus{
      outline:none;
      border-color:rgba(15,118,110,.7);
      box-shadow:0 0 0 4px rgba(15,118,110,.12);
      transform:translateY(-1px);
    }

    .actions,
    .topbar-actions,
    .filters{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      align-items:center;
    }

    .btn{
      border:0;
      border-radius:14px;
      padding:12px 16px;
      font:inherit;
      font-size:14px;
      font-weight:800;
      cursor:pointer;
      transition:transform .18s ease, box-shadow .18s ease, opacity .18s ease;
    }

    .btn:hover{transform:translateY(-1px)}
    .btn:disabled{cursor:not-allowed;opacity:.55;transform:none}
    .btn-primary{background:linear-gradient(135deg,var(--deep),var(--teal));color:#fff;box-shadow:0 12px 24px rgba(15,53,87,.18)}
    .btn-secondary{background:#e8eef6;color:var(--deep)}
    .btn-danger{background:#ba3a3a;color:#fff}
    .btn-ghost{background:transparent;border:1px solid #cfd8e6;color:var(--deep)}
    .btn-small{padding:9px 12px;font-size:13px;border-radius:12px}

    .alert{
      display:none;
      margin-top:14px;
      border-radius:16px;
      padding:13px 15px;
      font-size:14px;
      line-height:1.5;
    }

    .alert.show{display:block}
    .alert-error{background:var(--rose-soft);color:var(--rose);border:1px solid #f6bcbc}
    .alert-ok{background:#e7f7f1;color:#12665f;border:1px solid #bfe8dc}

    .app-shell{
      width:min(1320px,100% - 28px);
      margin:20px auto 36px;
    }

    .topbar{
      border-radius:28px;
      padding:18px 22px;
      display:flex;
      justify-content:space-between;
      gap:16px;
      align-items:center;
      margin-bottom:18px;
    }

    .topbar h2{
      margin:0;
      font-size:21px;
      font-weight:800;
      color:var(--deep);
    }

    .topbar-brand{
      display:flex;
      align-items:center;
      gap:14px;
      min-width:0;
    }

    .brand-logos{
      display:flex;
      align-items:center;
      gap:10px;
      flex-shrink:0;
    }

    .brand-logo{
      display:block;
      object-fit:contain;
      border-radius:18px;
      background:#fff;
      border:1px solid rgba(221,228,239,.95);
      box-shadow:0 10px 24px rgba(17,24,39,.08);
    }

    .brand-logo-school{
      width:58px;
      height:58px;
      padding:6px;
    }

    .brand-logo-profe{
      width:126px;
      height:58px;
      padding:8px 12px;
    }

    .brand-copy{
      min-width:0;
    }

    .shell-grid{
      display:grid;
      gap:18px;
    }

    .hero{
      display:grid;
      grid-template-columns:1.2fr .8fr;
      gap:18px;
    }

    .panel{
      border-radius:var(--radius);
      padding:22px;
    }

    .panel h3,
    .section-title{
      margin:0 0 8px;
      font-size:20px;
      font-weight:800;
      color:var(--deep);
    }

    .hero-copy{
      position:relative;
      overflow:hidden;
      background:
        linear-gradient(135deg, rgba(15,53,87,.98), rgba(15,118,110,.95)),
        linear-gradient(180deg,#123,#456);
      color:#fff;
      border-radius:30px;
      padding:28px;
      box-shadow:0 24px 50px rgba(15,53,87,.18);
    }

    .hero-copy .panel-note,
    .hero-copy .meta-line{color:rgba(235,243,250,.84)}

    .hero-copy::after{
      content:'';
      position:absolute;
      width:260px;
      height:260px;
      border-radius:50%;
      right:-90px;
      top:-90px;
      background:radial-gradient(circle, rgba(255,255,255,.22), rgba(255,255,255,0));
    }

    .course-strip{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      margin-top:18px;
    }

    .course-chip,
    .status-chip,
    .badge{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border-radius:999px;
      font-size:12px;
      font-weight:800;
      padding:7px 11px;
    }

    .course-chip{background:rgba(255,255,255,.14);color:#fff;border:1px solid rgba(255,255,255,.16)}

    .stats-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:12px;
    }

    .stat-card{
      background:#fff;
      border:1px solid #e1e8f2;
      border-radius:20px;
      padding:18px;
    }

    .stat-label{
      display:block;
      font-size:11px;
      letter-spacing:.08em;
      text-transform:uppercase;
      font-weight:800;
      color:#75839a;
      margin-bottom:8px;
    }

    .stat-value{
      display:block;
      font-size:30px;
      line-height:1;
      font-weight:900;
      color:var(--deep);
      letter-spacing:-.03em;
    }

    .layout-two{
      display:grid;
      grid-template-columns:1.45fr .85fr;
      gap:18px;
    }

    .weights-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:12px;
      margin:16px 0;
    }

    .table-wrap{
      overflow:auto;
      border:1px solid #e1e8f2;
      border-radius:18px;
      background:#fff;
    }

    table{
      width:100%;
      border-collapse:collapse;
      min-width:760px;
    }

    th,td{
      padding:14px 15px;
      text-align:left;
      border-bottom:1px solid #edf2f7;
      vertical-align:top;
    }

    th{
      font-size:11px;
      text-transform:uppercase;
      letter-spacing:.09em;
      color:#6d7d94;
      background:#f9fbfd;
      font-weight:800;
      position:sticky;
      top:0;
      z-index:1;
    }

    td{font-size:14px;color:var(--ink)}
    tr:hover td{background:#fbfdff}

    .cell-select{
      width:100%;
      min-width:72px;
      border:1px solid #d6deea;
      border-radius:10px;
      background:#fff;
      padding:8px 10px;
      font:inherit;
      font-size:13px;
      color:var(--ink);
    }

    .cell-select.value-L{background:#ecfbf1;border-color:#bfe4ce;color:#0d6a3e}
    .cell-select.value-ML{background:#fff6e5;border-color:#f0d9aa;color:#9a5c00}
    .cell-select.value-PL{background:#fff0de;border-color:#f2cfa3;color:#9d4700}
    .cell-select.value-NL{background:#ffebeb;border-color:#efc1c1;color:#a52525}
    .cell-select.value-A{background:#edf3ff;border-color:#c9d7ff;color:#3156a8}

    .cell-select:focus{
      outline:none;
      border-color:rgba(15,118,110,.7);
      box-shadow:0 0 0 3px rgba(15,118,110,.12);
    }

    .cell-select:disabled{
      background:#f4f7fb;
      color:#7a889c;
      cursor:not-allowed;
    }

    .cell-input{
      width:100%;
      min-width:84px;
      border:1px solid #d6deea;
      border-radius:10px;
      background:#fff;
      padding:8px 10px;
      font:inherit;
      font-size:13px;
      color:var(--ink);
    }

    .cell-input:focus{
      outline:none;
      border-color:rgba(15,118,110,.7);
      box-shadow:0 0 0 3px rgba(15,118,110,.12);
    }

    .cell-input:disabled{
      background:#f4f7fb;
      color:#7a889c;
      cursor:not-allowed;
    }

    .row-main{font-weight:700;color:var(--deep)}
    .row-mainline{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
    .row-sub{display:block;margin-top:4px;font-size:12px;color:#74839c}

    .status-L{background:#dff7e7;color:#0d6a3e}
    .status-ML{background:#fff2d9;color:#a05f00}
    .status-PL{background:#ffe7c7;color:#a14900}
    .status-NL{background:#ffe1e1;color:#a52525}
    .status-A{background:#e6eeff;color:#3156a8}
    .status-PIE,.status-NEEP,.status-NEET{background:#e4edff;color:#2145a6}
    .status-empty{background:#eef3f9;color:#6e7e93}

    .inline-grid{
      display:grid;
      grid-template-columns:1.2fr .8fr;
      gap:18px;
      align-items:start;
    }

    .preview-box{
      border:1px dashed #bfd0e3;
      border-radius:18px;
      padding:15px;
      background:#f9fbfe;
      min-height:218px;
    }

    .mapping-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:12px;
      margin-top:14px;
    }

    .toolbar{
      display:flex;
      justify-content:space-between;
      gap:12px;
      align-items:flex-start;
      margin-bottom:16px;
      flex-wrap:wrap;
    }

    .filters input,
    .filters select{
      min-width:170px;
      padding:11px 13px;
      border:1px solid #ced8e5;
      border-radius:13px;
      background:#fff;
      font:inherit;
    }

    .distribution-list{
      display:grid;
      gap:12px;
      margin-top:16px;
    }

    .distribution-item{
      display:grid;
      grid-template-columns:44px 1fr auto;
      gap:12px;
      align-items:center;
    }

    .bar-track{
      height:12px;
      border-radius:999px;
      background:#edf3f8;
      overflow:hidden;
    }

    .bar-fill{
      height:100%;
      border-radius:999px;
      background:linear-gradient(90deg,var(--teal),#36a1a0);
    }

    .empty-state{
      padding:28px;
      text-align:center;
      color:#70819a;
      border:1px dashed #c5d3e4;
      border-radius:18px;
      background:#fbfdff;
    }

    .toast{
      position:fixed;
      right:18px;
      bottom:18px;
      border-radius:16px;
      padding:13px 16px;
      color:#fff;
      font-weight:700;
      box-shadow:0 18px 40px rgba(17,24,39,.22);
      transform:translateY(18px);
      opacity:0;
      transition:opacity .22s ease, transform .22s ease;
      z-index:1200;
      pointer-events:none;
    }

    .toast.show{opacity:1;transform:translateY(0)}
    .toast.ok{background:#0f766e}
    .toast.err{background:#b93c3c}

    .modal-shell{
      position:fixed;
      inset:0;
      display:none;
      place-items:center;
      background:rgba(15,23,42,.42);
      z-index:1000;
      padding:18px;
    }

    .modal-shell.show{display:grid}

    .modal-card{
      width:min(640px,100%);
      background:#fff;
      border-radius:26px;
      box-shadow:0 24px 60px rgba(17,24,39,.18);
      padding:24px;
      border:1px solid #dde4ef;
    }

    .modal-head{
      display:flex;
      justify-content:space-between;
      gap:14px;
      align-items:flex-start;
      margin-bottom:16px;
    }

    .modal-head h4{
      margin:0 0 6px;
      font-size:22px;
      color:var(--deep);
    }

    .modal-actions{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      flex-wrap:wrap;
      margin-top:18px;
    }

    .pill-row{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      margin-top:8px;
    }

    .th-stack{
      display:flex;
      flex-direction:column;
      gap:2px;
      min-width:68px;
    }

    .th-date{
      font-weight:800;
      color:var(--deep);
      line-height:1.15;
    }

    .th-session{
      font-size:11px;
      letter-spacing:.08em;
      text-transform:uppercase;
      color:var(--muted);
    }

    @media (max-width: 1024px){
      .hero,
      .layout-two,
      .inline-grid{grid-template-columns:1fr}
    }

    @media (max-width: 720px){
      .app-shell{width:min(100% - 18px,1320px)}
      .topbar{padding:16px}
      .topbar-brand{align-items:flex-start}
      .brand-logos{gap:8px}
      .brand-logo-school{width:48px;height:48px}
      .brand-logo-profe{width:102px;height:48px}
      .panel{padding:18px}
      .stats-grid,
      .weights-grid,
      .mapping-grid{grid-template-columns:1fr}
      .topbar,
      .toolbar{align-items:stretch}
      .topbar-actions,
      .actions,
      .filters{width:100%}
      .topbar-actions .btn,
      .actions .btn{flex:1}
      .distribution-item{grid-template-columns:1fr}
    }
  </style>
</head>
<body>
  <div id="gate" class="gate-shell">
    <div class="gate-card">
      <h1>Nota de proceso U1</h1>
      <p class="gate-copy">Ingreso admin o PIE compartido.</p>

      <form id="gateForm">
        <div class="field-grid">
          <div class="field">
            <label for="loginEmail">Correo</label>
            <input id="loginEmail" type="email" autocomplete="username" placeholder="correo@estudiacest.com" required>
          </div>
          <div class="field">
            <label for="loginPassword">Clave</label>
            <input id="loginPassword" type="password" autocomplete="current-password" placeholder="Tu clave" required>
          </div>
          <div class="field">
            <label for="gatePieIdentity">Nombre si usas cuenta PIE</label>
            <select id="gatePieIdentity">
              <option value="">Selecciona tu nombre</option>
            </select>
            <div id="gateSharedHint" class="field-help"></div>
          </div>
        </div>
        <div class="actions">
          <button id="loginBtn" class="btn btn-primary" type="submit">Entrar al panel</button>
        </div>
        <div id="gateError" class="alert alert-error"></div>
      </form>
    </div>
  </div>

  <div id="app" class="app-shell hidden">
    <div class="topbar">
      <div class="topbar-brand">
        <div class="brand-logos">
          <img class="brand-logo brand-logo-school" src="../publicaciones/articulo-investigacion-2026/logo-cest.png" alt="Logo del colegio">
          <img class="brand-logo brand-logo-profe" src="../imagenes/logo-profe-francisco-nuevo.svg" alt="Logo de Profe Francisco">
        </div>
        <div class="brand-copy">
          <h2>Nota de proceso U1</h2>
        <div id="userMeta" class="meta-line">Verificando datos...</div>
        </div>
      </div>
      <div class="topbar-actions">
        <button id="refreshBtn" class="btn btn-secondary btn-small" type="button">Actualizar</button>
        <button id="exportBtn" class="btn btn-ghost btn-small" type="button">Exportar JSON</button>
        <button id="logoutBtn" class="btn btn-danger btn-small" type="button">Salir</button>
      </div>
    </div>

    <div class="shell-grid">
      <section class="hero">
        <article class="hero-copy">
          <div class="eyebrow">Unidad 1</div>
          <h1>Laboriosidad y participacion de curso</h1>
          <p class="panel-note">
            La planilla se calcula como promedio simple de las clases registradas en escala 1 a 7. Luego se combina con 15% autoevaluacion y 15% equipo de aula cuando esas notas existan.
          </p>
          <div class="course-strip" id="courseStrip"></div>
        </article>

        <article class="panel">
          <h3>Resumen general</h3>
          <p class="panel-note">Vista rapida de la base cargada en esta ruta.</p>
          <div id="statsGrid" class="stats-grid"></div>
          <div id="distributionList" class="distribution-list"></div>
        </article>
      </section>

      <section class="layout-two">
        <article class="panel">
          <div class="toolbar">
            <div>
              <h3 class="section-title">Promedio por curso</h3>
              <p class="panel-note">La planilla es el promedio de las clases ya registradas en escala 1 a 7. Si aun faltan autoevaluacion o equipo de aula, la nota se muestra solo con lo disponible.</p>
            </div>
          </div>
          <div id="coursesEmpty" class="empty-state hidden">Todavia no hay registros importados para Unidad 1.</div>
          <div id="coursesWrap" class="table-wrap hidden">
            <table>
              <thead>
                <tr>
                  <th>Curso</th>
                  <th>Estudiantes</th>
                  <th>Nota actual</th>
                  <th>Nivel base</th>
                  <th>L</th>
                  <th>ML</th>
                  <th>PL</th>
                  <th>NL</th>
                </tr>
              </thead>
              <tbody id="coursesBody"></tbody>
            </table>
          </div>
        </article>

        <article id="weightsPanel" class="panel">
          <h3 class="section-title">Ponderacion</h3>
          <p class="panel-note">La nota de proceso usa tres componentes. Puedes ajustar la ponderacion por componente y el valor interno de cada nivel.</p>
          <p id="weightsRoleNote" class="field-help"></p>
          <form id="weightsForm">
            <div class="weights-grid">
              <div>
                <label for="componentWeightPlanilla">Planilla (%)</label>
                <input id="componentWeightPlanilla" type="number" step="1" min="0">
              </div>
              <div>
                <label for="componentWeightAuto">Autoevaluacion (%)</label>
                <input id="componentWeightAuto" type="number" step="1" min="0">
              </div>
              <div>
                <label for="componentWeightTeam">Equipo de aula (%)</label>
                <input id="componentWeightTeam" type="number" step="1" min="0">
              </div>
            </div>
            <div class="weights-grid">
              <div>
                <label for="weightL">Valor L</label>
                <input id="weightL" type="number" step="0.1" min="0">
              </div>
              <div>
                <label for="weightML">Valor ML</label>
                <input id="weightML" type="number" step="0.1" min="0">
              </div>
              <div>
                <label for="weightPL">Valor PL</label>
                <input id="weightPL" type="number" step="0.1" min="0">
              </div>
              <div>
                <label for="weightNL">Valor NL</label>
                <input id="weightNL" type="number" step="0.1" min="0">
              </div>
            </div>
            <div class="actions">
              <button id="saveWeightsBtn" class="btn btn-primary btn-small" type="submit">Guardar ponderacion</button>
              <button id="resetWeightsBtn" class="btn btn-secondary btn-small" type="button">Volver a 70/15/15 y 4-3-2-1</button>
            </div>
          </form>
        </article>
      </section>

      <section class="panel">
        <div class="toolbar">
          <div>
            <h3 class="section-title">Detalle por estudiante</h3>
            <p class="panel-note">La base funciona como planilla: cada sesion se marca en la grilla y la columna Planilla se recalcula sola. El acceso PIE puede completar autoevaluacion y equipo de aula; la planilla por sesiones queda para la cuenta administradora.</p>
          </div>
          <div class="filters">
            <input id="searchInput" type="search" placeholder="Buscar estudiante o RUT">
            <select id="courseFilter"></select>
            <select id="statusFilter">
              <option value="">Todos los niveles finales</option>
              <option value="L">L</option>
              <option value="ML">ML</option>
              <option value="PL">PL</option>
              <option value="NL">NL</option>
            </select>
          </div>
        </div>
        <div id="studentsEmpty" class="empty-state hidden">Todavia no hay registros guardados.</div>
        <div id="studentsWrap" class="table-wrap hidden">
          <table>
            <thead>
              <tr id="studentsHead"></tr>
            </thead>
            <tbody id="studentsBody"></tbody>
          </table>
        </div>
      </section>
    </div>
  </div>

  <div id="editModal" class="modal-shell">
    <div class="modal-card">
      <div class="modal-head">
        <div>
          <h4>Editar registro</h4>
          <div id="editMeta" class="meta-line"></div>
        </div>
        <button id="closeModalBtn" class="btn btn-ghost btn-small" type="button">Cerrar</button>
      </div>
      <div class="field-grid">
        <div class="field">
          <label for="editCourse">Curso</label>
          <input id="editCourse" type="text">
        </div>
        <div class="field">
          <label for="editPlanilla">Planilla (70%)</label>
          <select id="editPlanilla">
            <option value="">Sin dato</option>
            <option value="L">L</option>
            <option value="ML">ML</option>
            <option value="PL">PL</option>
            <option value="NL">NL</option>
          </select>
        </div>
        <div class="field">
          <label for="editAuto">Autoevaluacion (15%)</label>
          <select id="editAuto">
            <option value="">Sin dato</option>
            <option value="L">L</option>
            <option value="ML">ML</option>
            <option value="PL">PL</option>
            <option value="NL">NL</option>
          </select>
        </div>
        <div class="field">
          <label for="editTeam">Equipo de aula (15%)</label>
          <select id="editTeam">
            <option value="">Sin dato</option>
            <option value="L">L</option>
            <option value="ML">ML</option>
            <option value="PL">PL</option>
            <option value="NL">NL</option>
          </select>
        </div>
        <div class="field" style="grid-column:1 / -1">
          <label for="editObservation">Observacion</label>
          <textarea id="editObservation" placeholder="Detalle breve del trabajo o la participacion"></textarea>
        </div>
      </div>
      <div class="pill-row">
        <span id="editRutBadge" class="badge" style="background:#eef3f9;color:#51627b"></span>
        <span id="editScoreBadge" class="badge" style="background:#d7f4ef;color:#0f766e"></span>
        <span id="editActorBadge" class="badge" style="background:#fff1d7;color:#8a5a16"></span>
      </div>
      <div class="modal-actions">
        <button id="deleteRecordBtn" class="btn btn-danger btn-small" type="button">Eliminar</button>
        <button id="saveRecordBtn" class="btn btn-primary btn-small" type="button">Guardar cambios</button>
      </div>
    </div>
  </div>

  <div id="toast" class="toast"></div>

  <script src="../js/firebase-config.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-database-compat.js"></script>
  <script>
    const STUDENT_BASE = 'plataforma_estudiantes';
    const NP_BASE = 'plataforma_np';
    const NP_UNIT = 'unidad1';
    const STATUS_ORDER = ['L', 'ML', 'PL', 'NL'];
    const COMPONENT_KEYS = ['planilla', 'auto', 'team'];
    const COMPONENT_LABELS = {
      planilla: 'Planilla',
      auto: 'Autoevaluacion',
      team: 'Equipo de aula'
    };
    const DEFAULT_STATUS_SCORES = { L: 4, ML: 3, PL: 2, NL: 1 };
    const DEFAULT_COMPONENT_WEIGHTS = { planilla: 70, auto: 15, team: 15 };
    const SESSION_NOTE_VALUES = { L: 3, ML: 2, PL: 1, NL: 0, A: 0 };
    const DEFAULT_SHARED_ACCESS = {
      email: 'pie.np@estudiacest.com',
      label: 'Acceso PIE compartido',
      staff: ['Francisco Núñez', 'Alicia Aguilera', 'Joselin Diaz', 'Pia Benavides']
    };
    const SHARED_ACCESS_STORAGE_KEY = 'np-shared-access-cache';
    const COURSE_ORDER = ['3A-TP', '3B-TP', '3D-TP', '4A-TP', '4B-TP', '4C-TP', '4D-TP', '4E-TP'];

    const app = firebase.apps.length ? firebase.app() : firebase.initializeApp(FIREBASE_CONFIG);
    const auth = firebase.auth();
    const db = firebase.database();

    const gate = document.getElementById('gate');
    const appShell = document.getElementById('app');
    const gateForm = document.getElementById('gateForm');
    const gateError = document.getElementById('gateError');
    const loginBtn = document.getElementById('loginBtn');
    const gatePieIdentity = document.getElementById('gatePieIdentity');
    const gateSharedHint = document.getElementById('gateSharedHint');
    const weightsRoleNote = document.getElementById('weightsRoleNote');
    const weightsPanel = document.getElementById('weightsPanel');
    const courseStrip = document.getElementById('courseStrip');
    const statsGrid = document.getElementById('statsGrid');
    const distributionList = document.getElementById('distributionList');
    const coursesBody = document.getElementById('coursesBody');
    const coursesWrap = document.getElementById('coursesWrap');
    const coursesEmpty = document.getElementById('coursesEmpty');
    const studentsHead = document.getElementById('studentsHead');
    const studentsBody = document.getElementById('studentsBody');
    const studentsWrap = document.getElementById('studentsWrap');
    const studentsEmpty = document.getElementById('studentsEmpty');
    const searchInput = document.getElementById('searchInput');
    const courseFilter = document.getElementById('courseFilter');
    const statusFilter = document.getElementById('statusFilter');
    const weightsForm = document.getElementById('weightsForm');
    const userMeta = document.getElementById('userMeta');
    const refreshBtn = document.getElementById('refreshBtn');
    const exportBtn = document.getElementById('exportBtn');
    const logoutBtn = document.getElementById('logoutBtn');
    const saveWeightsBtn = document.getElementById('saveWeightsBtn');
    const resetWeightsBtn = document.getElementById('resetWeightsBtn');
    const modal = document.getElementById('editModal');
    const editMeta = document.getElementById('editMeta');
    const editCourse = document.getElementById('editCourse');
    const editPlanilla = document.getElementById('editPlanilla');
    const editAuto = document.getElementById('editAuto');
    const editTeam = document.getElementById('editTeam');
    const editObservation = document.getElementById('editObservation');
    const editRutBadge = document.getElementById('editRutBadge');
    const editScoreBadge = document.getElementById('editScoreBadge');
    const editActorBadge = document.getElementById('editActorBadge');
    const closeModalBtn = document.getElementById('closeModalBtn');
    const saveRecordBtn = document.getElementById('saveRecordBtn');
    const deleteRecordBtn = document.getElementById('deleteRecordBtn');
    const toast = document.getElementById('toast');

    const componentWeightInputs = {
      planilla: document.getElementById('componentWeightPlanilla'),
      auto: document.getElementById('componentWeightAuto'),
      team: document.getElementById('componentWeightTeam')
    };
    const statusScoreInputs = {
      L: document.getElementById('weightL'),
      ML: document.getElementById('weightML'),
      PL: document.getElementById('weightPL'),
      NL: document.getElementById('weightNL')
    };

    let currentUser = null;
    let currentAccess = { role: 'guest', collaborator: '' };
    let sharedAccess = loadSharedAccessCache();
    let currentData = {
      records: {},
      importMeta: null,
      config: {
        statusScores: Object.assign({}, DEFAULT_STATUS_SCORES),
        componentWeights: Object.assign({}, DEFAULT_COMPONENT_WEIGHTS),
        sessionHeadersByCourse: {},
        pieTagsByRut: {}
      }
    };
    let liveBound = false;
    let editingId = null;

    populatePieIdentityOptions();
    updateGateSharedHint();
    gatePieIdentity.value = resolvePieCollaborator(window.localStorage.getItem('np-last-pie-collaborator') || '') || '';

    gateForm.addEventListener('submit', async function(event) {
      event.preventDefault();
      const email = document.getElementById('loginEmail').value.trim();
      const password = document.getElementById('loginPassword').value;
      if (!email || !password) {
        showGateError('Ingresa correo y contrasena.');
        return;
      }
      loginBtn.disabled = true;
      loginBtn.textContent = 'Validando...';
      gateError.classList.remove('show');
      try {
        await auth.signInWithEmailAndPassword(email, password);
      } catch (error) {
        showGateError('No fue posible ingresar. Revisa correo, contrasena o permisos de acceso.');
      } finally {
        loginBtn.disabled = false;
        loginBtn.textContent = 'Entrar al panel';
      }
    });

    refreshBtn.addEventListener('click', async function() {
      if (!currentUser) return;
      await currentUser.getIdToken(true);
      const snap = await db.ref(NP_BASE + '/' + NP_UNIT).once('value');
      currentData = normalizeData(snap.val());
      renderAll();
      showToast('Datos actualizados.', false);
    });

    exportBtn.addEventListener('click', function() {
      const payload = {
        exportedAt: new Date().toISOString(),
        unit: NP_UNIT,
        data: currentData
      };
      downloadFile('np-unidad1-' + compactDate() + '.json', JSON.stringify(payload, null, 2), 'application/json');
    });

    logoutBtn.addEventListener('click', async function() {
      await auth.signOut();
    });

    searchInput.addEventListener('input', renderStudentsTable);
    courseFilter.addEventListener('change', renderStudentsTable);
    statusFilter.addEventListener('change', renderStudentsTable);

    weightsForm.addEventListener('submit', async function(event) {
      event.preventDefault();
      if (!isAdminRole()) {
        showToast('La configuracion del modelo esta reservada para la cuenta administradora.', true);
        return;
      }
      const nextConfig = {
        componentWeights: readComponentWeightInputs(),
        statusScores: readStatusScoreInputs()
      };
      await db.ref(NP_BASE + '/' + NP_UNIT + '/config').set(nextConfig);
      showToast('Ponderacion actualizada.', false);
    });

    resetWeightsBtn.addEventListener('click', function() {
      fillComponentWeightInputs(DEFAULT_COMPONENT_WEIGHTS);
      fillStatusScoreInputs(DEFAULT_STATUS_SCORES);
    });

    studentsBody.addEventListener('click', function(event) {
      const button = event.target.closest('button[data-record-id]');
      if (!button) return;
      openEditModal(button.getAttribute('data-record-id'));
    });

    studentsBody.addEventListener('change', async function(event) {
      const control = event.target.closest('[data-grid-field]');
      if (!control) return;
      await updateGridCell(control);
    });

    closeModalBtn.addEventListener('click', closeEditModal);
    modal.addEventListener('click', function(event) {
      if (event.target === modal) closeEditModal();
    });

    saveRecordBtn.addEventListener('click', async function() {
      if (!editingId) return;
      if (!canWriteRecords()) {
        showToast('Tu perfil no tiene permisos para editar registros.', true);
        return;
      }
      if (isPieRole() && !currentAccess.collaborator) {
        showToast('El acceso PIE compartido debe marcar su nombre antes de guardar cambios.', true);
        return;
      }
      const currentRecord = currentData.records[editingId] || {};
      const planilla = isPieRole() ? normalizeStatus(currentRecord.components && currentRecord.components.planilla) : normalizeStatus(editPlanilla.value);
      const nextCourse = isPieRole() ? currentRecord.course : normalizeCourse(editCourse.value);
      if (!nextCourse) {
        showToast('El curso no puede quedar vacio.', true);
        return;
      }
      if (!planilla) {
        showToast('La planilla debe quedar marcada con L, ML, PL o NL.', true);
        return;
      }
      const updates = {
        course: nextCourse,
        status: planilla,
        observation: String(editObservation.value || '').trim(),
        components: {
          planilla: planilla,
          auto: normalizeStatus(editAuto.value),
          team: normalizeStatus(editTeam.value)
        },
        updatedAt: firebase.database.ServerValue.TIMESTAMP,
        updatedByRole: currentAccess.role,
        updatedByUid: currentUser ? currentUser.uid : '',
        updatedByDisplay: actorLabel()
      };
      await db.ref(NP_BASE + '/' + NP_UNIT + '/records/' + editingId).update(updates);
      closeEditModal();
      showToast('Registro actualizado.', false);
    });

    deleteRecordBtn.addEventListener('click', async function() {
      if (!editingId) return;
      if (!isAdminRole()) {
        showToast('Solo la cuenta administradora puede eliminar registros.', true);
        return;
      }
      const ok = window.confirm('Se eliminara este registro de la base. Continuar?');
      if (!ok) return;
      await db.ref(NP_BASE + '/' + NP_UNIT + '/records/' + editingId).remove();
      closeEditModal();
      showToast('Registro eliminado.', false);
    });

    auth.onAuthStateChanged(async function(user) {
      if (!user) {
        currentUser = null;
        currentAccess = { role: 'guest', collaborator: '' };
        hideApp();
        return;
      }
      try {
        await user.getIdToken(true);
        const adminSnap = await db.ref(STUDENT_BASE + '/admins/' + user.uid).once('value');
        if (adminSnap.val()) {
          currentUser = user;
          currentAccess = { role: 'admin', collaborator: '' };
          await refreshSharedAccessFromAdmin();
          showApp();
          bindLiveData();
          return;
        }

        const pieSnap = await db.ref(NP_BASE + '/access/allowedUids/' + user.uid).once('value');
        if (!pieSnap.val()) {
          await auth.signOut();
          showGateError('Tu cuenta no tiene permisos para acceder a /np.');
          return;
        }

        const collaborator = resolvePieCollaborator(gatePieIdentity.value || window.localStorage.getItem('np-last-pie-collaborator') || '');
        if (!collaborator) {
          await auth.signOut();
          showGateError('El acceso PIE compartido debe marcar su nombre antes de entrar.');
          return;
        }
        window.localStorage.setItem('np-last-pie-collaborator', collaborator);
        currentUser = user;
        currentAccess = { role: 'pie', collaborator: collaborator };
        showApp();
        bindLiveData();
      } catch (error) {
        console.error('[np/auth]', error);
        await auth.signOut();
        showGateError('No fue posible verificar permisos de acceso.');
      }
    });

    function bindLiveData() {
      if (liveBound) return;
      liveBound = true;
      db.ref(NP_BASE + '/' + NP_UNIT).on('value', function(snap) {
        currentData = normalizeData(snap.val());
        renderAll();
      }, function(error) {
        console.error('[np/live]', error);
        showToast('No fue posible leer la base de nota de proceso.', true);
      });
    }

    function showApp() {
      gate.classList.add('hidden');
      appShell.classList.remove('hidden');
      userMeta.textContent = accessSummary();
      gateError.classList.remove('show');
      applyRoleUi();
    }

    function hideApp() {
      appShell.classList.add('hidden');
      gate.classList.remove('hidden');
    }

    function applyRoleUi() {
      const adminOnly = !isAdminRole();
      Object.keys(componentWeightInputs).forEach(function(key) {
        componentWeightInputs[key].disabled = adminOnly;
      });
      Object.keys(statusScoreInputs).forEach(function(key) {
        statusScoreInputs[key].disabled = adminOnly;
      });
      saveWeightsBtn.disabled = adminOnly;
      resetWeightsBtn.disabled = adminOnly;

      weightsRoleNote.textContent = isAdminRole()
        ? 'Configuracion editable solo por la cuenta administradora.'
        : 'Acceso PIE compartido: aqui solo puedes revisar el modelo. La configuracion queda bloqueada para evitar cambios accidentales.';
      weightsPanel.style.opacity = isAdminRole() ? '1' : '.9';
    }

    function showGateError(message) {
      gateError.textContent = message;
      gateError.classList.add('show');
    }

    function populatePieIdentityOptions() {
      const currentValue = gatePieIdentity.value || window.localStorage.getItem('np-last-pie-collaborator') || '';
      gatePieIdentity.innerHTML = ['<option value="">Selecciona tu nombre</option>'].concat(sharedAccess.staff.map(function(name) {
        return '<option value="' + escapeHtml(name) + '">' + escapeHtml(name) + '</option>';
      })).join('');
      gatePieIdentity.value = resolvePieCollaborator(currentValue) || '';
    }

    function updateGateSharedHint() {
      const accountEmail = sharedAccess.email ? ('Cuenta PIE: ' + sharedAccess.email + '. ') : '';
      gateSharedHint.textContent = accountEmail + 'Solo si entras con esa cuenta compartida.';
    }

    function refreshSharedAccessCache(nextValue) {
      sharedAccess = sanitizeSharedAccess(nextValue);
      try {
        window.localStorage.setItem(SHARED_ACCESS_STORAGE_KEY, JSON.stringify(sharedAccess));
      } catch (error) {
        console.warn('[np/shared-access-cache]', error);
      }
      populatePieIdentityOptions();
      updateGateSharedHint();
    }

    async function refreshSharedAccessFromAdmin() {
      if (!isAdminRole()) return;
      try {
        const sharedSnap = await db.ref(NP_BASE + '/access/sharedAccount').once('value');
        if (sharedSnap.exists()) {
          refreshSharedAccessCache(sharedSnap.val());
        }
      } catch (error) {
        console.warn('[np/shared-access]', error);
      }
    }

    function loadSharedAccessCache() {
      try {
        const cached = window.localStorage.getItem(SHARED_ACCESS_STORAGE_KEY);
        return sanitizeSharedAccess(cached ? JSON.parse(cached) : DEFAULT_SHARED_ACCESS);
      } catch (error) {
        return sanitizeSharedAccess(DEFAULT_SHARED_ACCESS);
      }
    }

    function sanitizeSharedAccess(value) {
      const raw = value || {};
      const mergedStaff = [];
      [].concat(DEFAULT_SHARED_ACCESS.staff || [], raw.staff || []).forEach(function(name) {
        const clean = normalizePersonName(name);
        if (!clean) return;
        if (mergedStaff.some(function(existing) { return normalizeLoose(existing) === normalizeLoose(clean); })) return;
        mergedStaff.push(clean);
      });
      return {
        email: String(raw.email || DEFAULT_SHARED_ACCESS.email || '').trim(),
        label: String(raw.label || DEFAULT_SHARED_ACCESS.label || '').trim(),
        staff: mergedStaff
      };
    }

    function resolvePieCollaborator(value) {
      const clean = normalizePersonName(value);
      if (!clean) return '';
      for (var index = 0; index < sharedAccess.staff.length; index += 1) {
        if (normalizeLoose(sharedAccess.staff[index]) === normalizeLoose(clean)) {
          return sharedAccess.staff[index];
        }
      }
      return '';
    }

    function normalizeData(value) {
      const raw = value || {};
      const legacyScores = raw.config && raw.config.weights ? raw.config.weights : null;
      return {
        records: normalizeRecords(raw.records || {}),
        importMeta: raw.importMeta || null,
        config: {
          statusScores: sanitizeStatusScores(raw.config && raw.config.statusScores ? raw.config.statusScores : (legacyScores || DEFAULT_STATUS_SCORES)),
          componentWeights: sanitizeComponentWeights(raw.config && raw.config.componentWeights ? raw.config.componentWeights : DEFAULT_COMPONENT_WEIGHTS),
          sessionHeadersByCourse: sanitizeSessionHeadersByCourse(raw.config && raw.config.sessionHeadersByCourse ? raw.config.sessionHeadersByCourse : {}),
          pieTagsByRut: sanitizePieTagsByRut(raw.config && raw.config.pieTagsByRut ? raw.config.pieTagsByRut : {})
        }
      };
    }

    function sanitizePieTagsByRut(value) {
      const next = {};
      Object.keys(value || {}).forEach(function(rutKey) {
        const cleanRutKey = rutLookupKey(rutKey);
        const raw = value[rutKey];
        const label = normalizePieLabel(typeof raw === 'string' ? raw : (raw && (raw.label || raw.type || raw.kind || raw.category)));
        if (cleanRutKey && label) {
          next[cleanRutKey] = { label: label };
        }
      });
      return next;
    }

    function sanitizeSessionHeadersByCourse(value) {
      const next = {};
      Object.keys(value || {}).forEach(function(courseKey) {
        const course = normalizeCourse(courseKey) || String(courseKey).trim();
        const courseHeaders = value[courseKey] || {};
        const normalizedHeaders = {};
        Object.keys(courseHeaders).forEach(function(indexKey) {
          const sessionIndex = Number(indexKey);
          const label = String(courseHeaders[indexKey] || '').trim();
          if (sessionIndex > 0 && label) {
            normalizedHeaders[sessionIndex] = label;
          }
        });
        if (Object.keys(normalizedHeaders).length) {
          next[course] = normalizedHeaders;
        }
      });
      return next;
    }

    function normalizeRecords(records) {
      const next = {};
      Object.keys(records || {}).forEach(function(id) {
        const record = records[id] || {};
        next[id] = {
          name: normalizePersonName(record.name),
          course: normalizeCourse(record.course),
          rut: cleanRut(record.rut),
          observation: String(record.observation || '').trim(),
          rowIndex: record.rowIndex || null,
          updatedAt: record.updatedAt || null,
          updatedByDisplay: record.updatedByDisplay || record.updatedBy || '',
          updatedByRole: record.updatedByRole || '',
          components: normalizeComponents(record),
          grades: normalizeGrades(record)
        };
      });
      return next;
    }

    function normalizeComponents(record) {
      const components = record.components || {};
      return {
        planilla: normalizeStatus(components.planilla || record.planilla || record.status || ''),
        auto: normalizeStatus(components.auto || record.auto || record.autoevaluacion || ''),
        team: normalizeStatus(components.team || record.team || record.equipo || record.equipoAula || '')
      };
    }

    function normalizeGrades(record) {
      const grades = record.grades || {};
      return {
        auto: normalizeGrade(grades.auto || record.autoGrade || record.autoevaluacionNota || ''),
        team: normalizeGrade(grades.team || record.teamGrade || record.equipoNota || record.equipoAulaNota || '')
      };
    }

    function normalizeGrade(value) {
      const raw = String(value == null ? '' : value).trim();
      if (!raw) return '';
      const parsed = Number(raw.replace(',', '.'));
      return Number.isFinite(parsed) ? parsed : '';
    }

    function sanitizeStatusScores(scores) {
      const next = {};
      STATUS_ORDER.forEach(function(status) {
        const parsed = Number(scores && scores[status]);
        next[status] = Number.isFinite(parsed) ? parsed : DEFAULT_STATUS_SCORES[status];
      });
      return next;
    }

    function sanitizeComponentWeights(weights) {
      const next = {};
      COMPONENT_KEYS.forEach(function(key) {
        const parsed = Number(weights && weights[key]);
        next[key] = Number.isFinite(parsed) ? parsed : DEFAULT_COMPONENT_WEIGHTS[key];
      });
      return next;
    }

    function fillStatusScoreInputs(scores) {
      STATUS_ORDER.forEach(function(status) {
        statusScoreInputs[status].value = String(scores[status]);
      });
    }

    function fillComponentWeightInputs(weights) {
      COMPONENT_KEYS.forEach(function(key) {
        componentWeightInputs[key].value = String(weights[key]);
      });
    }

    function readStatusScoreInputs() {
      return sanitizeStatusScores(Object.keys(statusScoreInputs).reduce(function(accumulator, status) {
        accumulator[status] = Number(statusScoreInputs[status].value);
        return accumulator;
      }, {}));
    }

    function readComponentWeightInputs() {
      return sanitizeComponentWeights(Object.keys(componentWeightInputs).reduce(function(accumulator, key) {
        accumulator[key] = Number(componentWeightInputs[key].value);
        return accumulator;
      }, {}));
    }

    function renderAll() {
      fillStatusScoreInputs(currentData.config.statusScores);
      fillComponentWeightInputs(currentData.config.componentWeights);
      renderCourseStrip();
      renderStats();
      renderDistribution();
      renderCoursesTable();
      renderStudentsTable();
      renderCourseFilterOptions();
    }

    function renderCourseStrip() {
      const ordered = buildOrderedCourses(uniqueCourses());
      courseStrip.innerHTML = ordered.map(function(course) {
        return '<span class="course-chip">' + escapeHtml(courseLabel(course)) + '</span>';
      }).join('');
    }

    function renderStats() {
      const records = listRecords();
      const outcomes = records.map(function(record) { return recordOutcome(record); });
      const withOutcome = outcomes.filter(function(outcome) { return outcome.note !== '' && outcome.note !== null; });
      const globalAverage = withOutcome.length ? (withOutcome.reduce(function(total, outcome) { return total + outcome.note; }, 0) / withOutcome.length).toFixed(1) : '0.0';
      const completeCount = outcomes.filter(function(outcome) { return outcome.isComplete; }).length;
      const averageStatus = withOutcome.length ? dominantStatus(outcomes.map(function(outcome) { return outcome.status; })) : 'Sin base';
      const cards = [
        { label: 'Estudiantes', value: String(records.length), sub: 'Registros activos en Unidad 1' },
        { label: 'Cursos', value: String(uniqueCourses().length), sub: 'Cursos detectados en la base' },
        { label: 'Nota global', value: globalAverage, sub: 'Promedio actual con 70/15/15' },
        { label: 'Completos', value: String(completeCount), sub: averageStatus === 'Sin base' ? 'Sin base aun' : ('Nivel base predominante: ' + averageStatus) }
      ];
      statsGrid.innerHTML = cards.map(function(card) {
        return '<div class="stat-card">'
          + '<span class="stat-label">' + escapeHtml(card.label) + '</span>'
          + '<span class="stat-value">' + escapeHtml(card.value) + '</span>'
          + '<span class="row-sub">' + escapeHtml(card.sub) + '</span>'
          + '</div>';
      }).join('');
    }

    function renderDistribution() {
      const outcomes = listRecords().map(function(record) { return recordOutcome(record); }).filter(function(outcome) { return outcome.status; });
      const total = outcomes.length || 1;
      distributionList.innerHTML = STATUS_ORDER.map(function(status) {
        const count = outcomes.filter(function(outcome) { return outcome.status === status; }).length;
        const width = Math.round((count / total) * 100);
        return '<div class="distribution-item">'
          + '<span class="status-chip status-' + status + '">' + status + '</span>'
          + '<div class="bar-track"><div class="bar-fill" style="width:' + width + '%"></div></div>'
          + '<strong>' + count + '</strong>'
          + '</div>';
      }).join('');
    }

    function renderCoursesTable() {
      const summaries = summarizeCourses();
      if (!summaries.length) {
        coursesEmpty.classList.remove('hidden');
        coursesWrap.classList.add('hidden');
        coursesBody.innerHTML = '';
        return;
      }
      coursesEmpty.classList.add('hidden');
      coursesWrap.classList.remove('hidden');
      coursesBody.innerHTML = summaries.map(function(summary) {
        return '<tr>'
          + '<td><span class="row-main">' + escapeHtml(courseLabel(summary.course)) + '</span><span class="row-sub">Componentes completos: ' + summary.complete + '/' + summary.total + '</span></td>'
          + '<td>' + summary.total + '</td>'
          + '<td>' + summary.average.toFixed(1) + '</td>'
          + '<td><span class="status-chip status-' + summary.averageStatus + '">' + summary.averageStatus + '</span></td>'
          + '<td>' + summary.counts.L + '</td>'
          + '<td>' + summary.counts.ML + '</td>'
          + '<td>' + summary.counts.PL + '</td>'
          + '<td>' + summary.counts.NL + '</td>'
          + '</tr>';
      }).join('');
    }

    function renderStudentsTable() {
      const records = filteredRecords();
      const headerCourse = resolveVisibleSessionCourse(records.length ? records : listRecords());
      const sessionSource = courseFilter.value
        ? listRecords().filter(function(record) { return record.course === courseFilter.value; })
        : (records.length ? records : listRecords());
      const sessionIndices = collectSessionIndices(sessionSource, headerCourse);
      renderStudentsHead(sessionIndices, headerCourse);
      if (!listRecords().length) {
        studentsEmpty.classList.remove('hidden');
        studentsWrap.classList.add('hidden');
        studentsBody.innerHTML = '';
        return;
      }
      studentsEmpty.classList.add('hidden');
      studentsWrap.classList.remove('hidden');
      if (!records.length) {
        studentsBody.innerHTML = '<tr><td colspan="' + studentsColumnCount(sessionIndices) + '"><div class="empty-state">No hay coincidencias con los filtros actuales.</div></td></tr>';
        return;
      }
      studentsBody.innerHTML = records.map(function(record) {
        const outcome = recordOutcome(record);
        const observation = parseObservationParts(record.observation);
        const note = observation.note;
        const visibleUpdatedBy = visibleUpdatedByDisplay(record.updatedByDisplay);
        return '<tr>'
          + '<td><span class="row-mainline"><span class="row-main">' + escapeHtml(record.name) + '</span>' + renderPieTag(record) + '</span>'
          + (record.rut ? '<span class="row-sub">' + escapeHtml(record.rut) + '</span>' : '')
          + (note ? '<span class="row-sub">' + escapeHtml(note) + '</span>' : '')
          + (visibleUpdatedBy ? '<span class="row-sub">Ultimo cambio: ' + escapeHtml(visibleUpdatedBy) + '</span>' : '')
          + '</td>'
          + '<td>' + escapeHtml(courseLabel(record.course)) + '</td>'
          + sessionIndices.map(function(sessionIndex) {
            return '<td>' + renderSessionCell(record, sessionIndex) + '</td>';
          }).join('')
          + '<td>' + renderStatusChip(record.components.planilla) + '</td>'
          + '<td>' + renderComponentCell(record, 'auto') + '</td>'
          + '<td>' + renderComponentCell(record, 'team') + '</td>'
          + '<td>' + escapeHtml(outcome.noteText) + '<span class="row-sub">Cobertura ' + outcome.coverageLabel + '</span></td>'
          + '<td>' + renderStatusChip(outcome.status) + '</td>'
          + '</tr>';
      }).join('');
    }

    function renderStudentsHead(sessionIndices, sessionCourse) {
      const baseHeaders = ['Estudiante', 'Curso'];
      const trailingHeaders = ['Planilla', 'Auto 15%', 'Equipo 15%', 'Nota actual', 'Nivel base'];
      studentsHead.innerHTML = baseHeaders.map(function(label) {
        return '<th>' + escapeHtml(label) + '</th>';
      }).join('') + sessionIndices.map(function(sessionIndex) {
        return '<th>' + renderSessionHeaderCell(sessionCourse, sessionIndex) + '</th>';
      }).join('') + trailingHeaders.map(function(label) {
        return '<th>' + escapeHtml(label) + '</th>';
      }).join('');
    }

    function resolveVisibleSessionCourse(records) {
      if (courseFilter.value) return courseFilter.value;
      const courses = Array.from(new Set((records || []).map(function(record) { return record.course; }).filter(Boolean)));
      return courses.length === 1 ? courses[0] : '';
    }

    function renderSessionHeaderCell(course, sessionIndex) {
      const dateLabel = sessionDateLabel(course, sessionIndex);
      if (!dateLabel) {
        return escapeHtml('S' + sessionIndex);
      }
      return '<span class="th-stack"><span class="th-date">' + escapeHtml(dateLabel) + '</span><span class="th-session">S' + escapeHtml(String(sessionIndex)) + '</span></span>';
    }

    function sessionDateLabel(course, sessionIndex) {
      const courseKey = normalizeCourse(course);
      if (!courseKey) return '';
      const courseHeaders = currentData.config.sessionHeadersByCourse[courseKey] || {};
      return String(courseHeaders[sessionIndex] || courseHeaders[String(sessionIndex)] || '').trim();
    }

    function studentsColumnCount(sessionIndices) {
      return 7 + sessionIndices.length;
    }

    function collectSessionIndices(records, course) {
      const seen = new Set();
      (records || []).forEach(function(record) {
        const sessions = parseObservationParts(record.observation).sessions;
        Object.keys(sessions).forEach(function(key) {
          const index = Number(key);
          if (index > 0) seen.add(index);
        });
      });
      const courseKey = normalizeCourse(course);
      if (courseKey && currentData.config && currentData.config.sessionHeadersByCourse && currentData.config.sessionHeadersByCourse[courseKey]) {
        Object.keys(currentData.config.sessionHeadersByCourse[courseKey]).forEach(function(key) {
          const index = Number(key);
          if (index > 0) seen.add(index);
        });
      }
      return Array.from(seen).sort(function(left, right) { return left - right; });
    }

    function renderSessionCell(record, sessionIndex) {
      const sessions = parseObservationParts(record.observation).sessions;
      const value = sessions[sessionIndex] || '';
      return renderGridSelect(record.id, 'session', value, [
        { value: '', label: '—' },
        { value: 'A', label: 'A' },
        { value: 'L', label: 'L' },
        { value: 'ML', label: 'ML' },
        { value: 'PL', label: 'PL' },
        { value: 'NL', label: 'NL' }
      ], !isAdminRole(), ' data-session-index="' + sessionIndex + '"');
    }

    function renderComponentCell(record, key) {
      return renderGradeInput(record.id, key, record.grades[key]);
    }

    function renderGridSelect(recordId, field, value, options, disabled, extraAttributes) {
      const attrs = 'class="cell-select' + escapeHtml(gridSelectValueClass(value)) + '" data-record-id="' + escapeHtml(recordId) + '" data-grid-field="' + escapeHtml(field) + '"' + (extraAttributes || '') + (disabled ? ' disabled' : '');
      return '<select ' + attrs + '>' + options.map(function(option) {
        return '<option value="' + escapeHtml(option.value) + '"' + (option.value === value ? ' selected' : '') + '>' + escapeHtml(option.label) + '</option>';
      }).join('') + '</select>';
    }

    function gridSelectValueClass(value) {
      const clean = normalizeSessionStatus(value);
      if (!clean) return ' value-empty';
      return ' value-' + clean;
    }

    function renderGradeInput(recordId, key, value) {
      const normalized = value === '' ? '' : String(value);
      return '<input class="cell-input" type="number" step="0.1" min="1" data-record-id="' + escapeHtml(recordId) + '" data-grid-field="grade" data-grade-key="' + escapeHtml(key) + '" value="' + escapeHtml(normalized) + '"' + (!canWriteRecords() ? ' disabled' : '') + '>';
    }

    async function updateGridCell(select) {
      const recordId = select.getAttribute('data-record-id');
      const field = select.getAttribute('data-grid-field');
      const record = currentData.records[recordId];
      if (!record) return;
      if (!canWriteRecords()) {
        showToast('Tu perfil no tiene permisos para editar registros.', true);
        renderStudentsTable();
        return;
      }
      if (isPieRole() && !currentAccess.collaborator) {
        showToast('El acceso PIE compartido debe marcar su nombre antes de guardar cambios.', true);
        renderStudentsTable();
        return;
      }
      if (field === 'session' && !isAdminRole()) {
        showToast('La planilla por sesiones queda reservada para la cuenta administradora.', true);
        renderStudentsTable();
        return;
      }

      const observation = parseObservationParts(record.observation);
      const updates = {
        updatedAt: firebase.database.ServerValue.TIMESTAMP,
        updatedByRole: currentAccess.role,
        updatedByUid: currentUser ? currentUser.uid : '',
        updatedByDisplay: actorLabel()
      };

      if (field === 'session') {
        const sessionIndex = Number(select.getAttribute('data-session-index'));
        const nextValue = normalizeSessionStatus(select.value);
        if (sessionIndex > 0) {
          if (nextValue) {
            observation.sessions[sessionIndex] = nextValue;
          } else {
            delete observation.sessions[sessionIndex];
          }
        }
        const nextPlanilla = derivePlanillaFromSessions(observation.sessions);
        updates.status = nextPlanilla;
        updates.observation = buildObservation(observation.sessions, observation.note);
        updates.components = {
          planilla: nextPlanilla,
          auto: record.components.auto || '',
          team: record.components.team || ''
        };
      } else if (field === 'grade') {
        const gradeKey = select.getAttribute('data-grade-key');
        updates.grades = {
          auto: gradeKey === 'auto' ? normalizeGrade(select.value) : record.grades.auto,
          team: gradeKey === 'team' ? normalizeGrade(select.value) : record.grades.team
        };
      }

      await db.ref(NP_BASE + '/' + NP_UNIT + '/records/' + recordId).update(updates);
      showToast(field === 'session' ? 'Sesion actualizada.' : 'Nota actualizada.', false);
    }

    function renderCourseFilterOptions() {
      const currentValue = courseFilter.value;
      const options = ['<option value="">Todos los cursos</option>'].concat(buildOrderedCourses(uniqueCourses()).map(function(course) {
        return '<option value="' + escapeHtml(course) + '">' + escapeHtml(courseLabel(course)) + '</option>';
      }));
      courseFilter.innerHTML = options.join('');
      const validValues = buildOrderedCourses(uniqueCourses());
      courseFilter.value = validValues.indexOf(currentValue) >= 0 ? currentValue : '';
    }

    function filteredRecords() {
      const query = normalizeLoose(searchInput.value);
      const course = courseFilter.value;
      const status = statusFilter.value;
      return listRecords().filter(function(record) {
        const outcome = recordOutcome(record);
        if (course && record.course !== course) return false;
        if (status && outcome.status !== status) return false;
        if (!query) return true;
        const haystack = normalizeLoose([record.name, record.rut, record.course, record.observation, record.updatedByDisplay].join(' '));
        return haystack.indexOf(query) >= 0;
      });
    }

    function openEditModal(recordId) {
      const record = currentData.records[recordId];
      if (!record) return;
      editingId = recordId;
      const outcome = recordOutcome(record);
      const visibleUpdatedBy = visibleUpdatedByDisplay(record.updatedByDisplay);
      editMeta.textContent = record.name + ' · ' + courseLabel(record.course);
      editCourse.value = record.course || '';
      editPlanilla.value = record.components.planilla || '';
      editAuto.value = record.components.auto || '';
      editTeam.value = record.components.team || '';
      editObservation.value = record.observation || '';
      editRutBadge.textContent = record.rut ? 'RUT ' + record.rut : 'Sin RUT';
      editScoreBadge.textContent = outcome.status ? ('Nota ' + outcome.noteText + ' · ' + outcome.status + ' · cobertura ' + outcome.coverageLabel) : 'Sin componentes suficientes';
      editActorBadge.textContent = visibleUpdatedBy ? ('Ultimo cambio: ' + visibleUpdatedBy) : 'Sin historial de cambios';
      editCourse.disabled = isPieRole();
      editPlanilla.disabled = isPieRole();
      deleteRecordBtn.classList.toggle('hidden', !isAdminRole());
      modal.classList.add('show');
    }

    function closeEditModal() {
      editingId = null;
      modal.classList.remove('show');
    }

    function listRecords() {
      return Object.keys(currentData.records || {}).map(function(id) {
        const record = currentData.records[id] || {};
        return Object.assign({ id: id }, record);
      }).sort(function(left, right) {
        return courseLabel(left.course).localeCompare(courseLabel(right.course), 'es') || left.name.localeCompare(right.name, 'es');
      });
    }

    function uniqueCourses() {
      return Array.from(new Set(listRecords().map(function(record) { return record.course; }).filter(Boolean)));
    }

    function summarizeCourses() {
      return buildOrderedCourses(uniqueCourses()).map(function(course) {
        const rows = listRecords().filter(function(record) { return record.course === course; });
        if (!rows.length) return null;
        const outcomes = rows.map(function(record) { return recordOutcome(record); }).filter(function(outcome) { return outcome.status; });
        const counts = { L: 0, ML: 0, PL: 0, NL: 0 };
        outcomes.forEach(function(outcome) { counts[outcome.status] += 1; });
        const average = outcomes.length ? outcomes.reduce(function(total, outcome) { return total + outcome.note; }, 0) / outcomes.length : 0;
        return {
          course: course,
          total: rows.length,
          complete: outcomes.filter(function(outcome) { return outcome.isComplete; }).length,
          counts: counts,
          average: average,
          averageStatus: dominantStatus(outcomes.map(function(outcome) { return outcome.status; })) || 'L'
        };
      }).filter(Boolean);
    }

    function recordOutcome(record) {
      const componentWeights = currentData.config.componentWeights;
      const planillaMetrics = derivePlanillaMetrics(parseObservationParts(record.observation).sessions, record.components.planilla);
      const gradeMap = {
        planilla: planillaMetrics.note,
        auto: record.grades.auto,
        team: record.grades.team
      };
      let sum = 0;
      let usedWeight = 0;
      COMPONENT_KEYS.forEach(function(key) {
        const weight = Number(componentWeights[key] || 0);
        const score = normalizeGrade(gradeMap[key]);
        if (score === '' || weight <= 0) return;
        usedWeight += weight;
        sum += score * weight;
      });
      const totalWeight = COMPONENT_KEYS.reduce(function(total, key) { return total + Number(componentWeights[key] || 0); }, 0) || 0;
      const note = usedWeight ? sum / usedWeight : '';
      return {
        note: note,
        noteText: usedWeight ? note.toFixed(1) : '—',
        status: planillaMetrics.status,
        usedWeight: usedWeight,
        coverageLabel: totalWeight ? (Math.round((usedWeight / totalWeight) * 100) + '%') : '0%',
        isComplete: totalWeight > 0 && usedWeight >= totalWeight,
        planillaNote: planillaMetrics.note,
        planillaNoteText: planillaMetrics.noteText
      };
    }

    function scoreForStatus(status, statusScores) {
      const clean = normalizeStatus(status);
      if (!clean) return null;
      const score = Number(statusScores[clean]);
      return Number.isFinite(score) ? score : null;
    }

    function statusFromScore(score, statusScores) {
      const ranked = STATUS_ORDER.map(function(status) {
        return { status: status, score: Number(statusScores[status] || 0) };
      });
      ranked.sort(function(left, right) {
        return Math.abs(left.score - score) - Math.abs(right.score - score);
      });
      return ranked[0] ? ranked[0].status : 'L';
    }

    function canWriteRecords() {
      return isAdminRole() || isPieRole();
    }

    function isAdminRole() {
      return currentAccess.role === 'admin';
    }

    function isPieRole() {
      return currentAccess.role === 'pie';
    }

    function actorLabel() {
      if (isPieRole()) return 'PIE compartido · ' + currentAccess.collaborator;
      if (currentUser && currentUser.displayName) return currentUser.displayName;
      if (currentUser && currentUser.email) return currentUser.email;
      return currentUser ? currentUser.uid : 'sin-usuario';
    }

    function accessSummary() {
      if (isPieRole()) {
        return 'Acceso PIE compartido · ' + currentAccess.collaborator;
      }
      const label = userIdentityLabel();
      return label ? ('Cuenta administradora · ' + label) : 'Cuenta administradora';
    }

    function userIdentityLabel() {
      if (currentUser && currentUser.displayName) {
        const display = String(currentUser.displayName).trim();
        const raw = normalizeLoose(display);
        if (raw.indexOf('ADMINISTRADOR') >= 0 || raw.indexOf('PORTAFOLIO') >= 0) return '';
        return display;
      }
      if (currentUser && currentUser.email) return currentUser.email;
      return currentUser ? currentUser.uid : 'admin';
    }

    function normalizePieLabel(value) {
      const raw = normalizeLoose(value);
      if (!raw) return '';
      if (raw.indexOf('NEEP') >= 0) return 'NEEP';
      if (raw.indexOf('NEET') >= 0) return 'NEET';
      if (raw.indexOf('PIE') >= 0) return 'PIE';
      return '';
    }

    function resolvePieTag(record) {
      const rut = rutLookupKey(record && record.rut);
      if (!rut) return '';
      const map = currentData.config && currentData.config.pieTagsByRut ? currentData.config.pieTagsByRut : {};
      const raw = map[rut];
      return normalizePieLabel(typeof raw === 'string' ? raw : (raw && raw.label));
    }

    function renderPieTag(record) {
      const label = resolvePieTag(record);
      if (!label) return '';
      return '<span class="badge status-' + (label === 'PIE' ? 'PIE' : label) + '">' + escapeHtml(label) + '</span>';
    }

    function visibleUpdatedByDisplay(value) {
      const text = String(value || '').trim();
      return isSystemImportActor(text) ? '' : text;
    }

    function isSystemImportActor(value) {
      const raw = normalizeLoose(value);
      return raw.indexOf('CARGA ASISTIDA') >= 0 || raw.indexOf('GITHUB COPILOT') >= 0;
    }

    function renderStatusChip(status) {
      const clean = normalizeSessionStatus(status);
      if (!clean) return '<span class="status-chip status-empty">—</span>';
      return '<span class="status-chip status-' + clean + '">' + clean + '</span>';
    }

    function buildOrderedCourses(courses) {
      const extras = (courses || []).filter(function(course) { return COURSE_ORDER.indexOf(course) === -1; }).sort(function(a, b) {
        return courseLabel(a).localeCompare(courseLabel(b), 'es');
      });
      return COURSE_ORDER.filter(function(course) { return (courses || []).indexOf(course) >= 0; }).concat(extras);
    }

    function normalizeCourse(value) {
      const raw = normalizeLoose(value).replace(/[°º]/g, '');
      if (!raw) return '';
      const compact = raw.replace(/[^0-9A-Z]/g, '');
      let match = compact.match(/^([0-9])([A-Z])(TP)?$/);
      if (match) return match[1] + match[2] + '-TP';
      match = raw.match(/([0-9])\s*([A-Z])/);
      if (match) return match[1] + match[2] + '-TP';
      return raw.trim();
    }

    function normalizeStatus(value) {
      const raw = normalizeLoose(value);
      if (!raw) return '';
      if (raw === 'L' || raw === 'LOGRADO' || raw.indexOf('CASI TODO') >= 0 || raw.indexOf('TODO') >= 0) return 'L';
      if (raw === 'ML' || raw.indexOf('MAS DE LA MITAD') >= 0 || raw.indexOf('MAYOR PARTE') >= 0) return 'ML';
      if (raw === 'PL' || raw.indexOf('MENOS DE LA MITAD') >= 0 || raw.indexOf('POCO') >= 0 || raw.indexOf('PARCIAL') >= 0) return 'PL';
      if (raw === 'NL' || raw.indexOf('NADA') >= 0 || raw.indexOf('CASI NADA') >= 0) return 'NL';
      return '';
    }

    function normalizeSessionStatus(value) {
      const raw = normalizeLoose(value);
      if (!raw) return '';
      if (raw === 'A' || raw.indexOf('AUSENTE') >= 0 || raw.indexOf('INASIST') >= 0) return 'A';
      return normalizeStatus(raw);
    }

    function normalizePersonName(value) {
      return String(value || '').replace(/\s+/g, ' ').trim();
    }

    function normalizeLoose(value) {
      return String(value || '')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/\s+/g, ' ')
        .trim()
        .toUpperCase();
    }

    function cleanRut(value) {
      return String(value || '').replace(/\s+/g, '').toUpperCase();
    }

    function rutLookupKey(value) {
      return String(value || '').replace(/[^0-9kK]/g, '').toUpperCase();
    }

    function buildRecordKey(name, course, rut, index) {
      const base = normalizeLoose(course + '-' + name + '-' + (rut || index))
        .replace(/[^A-Z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '')
        .slice(0, 100);
      return base || ('REG-' + index);
    }

    function parseObservationParts(observation) {
      const text = String(observation || '').trim();
      const sessions = {};
      const matches = text.match(/S\d+\s*=\s*[A-Z]+/gi) || [];
      matches.forEach(function(token) {
        const parts = String(token).split('=');
        const sessionIndex = Number(String(parts[0] || '').replace(/[^0-9]/g, ''));
        const status = normalizeSessionStatus(parts[1]);
        if (sessionIndex > 0 && status) {
          sessions[sessionIndex] = status;
        }
      });
      const note = text
        .replace(/(?:^|\s*[,;|]?\s*)S\d+\s*=\s*[A-Z]+/gi, ' ')
        .replace(/\s*[|,;]\s*/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
      return { sessions: sessions, note: note };
    }

    function buildObservation(sessions, note) {
      const sessionText = Object.keys(sessions || {})
        .map(function(key) { return Number(key); })
        .filter(function(key) { return key > 0 && sessions[key]; })
        .sort(function(left, right) { return left - right; })
        .map(function(key) {
          return 'S' + key + '=' + sessions[key];
        })
        .join(', ');
      const cleanNote = String(note || '').trim();
      return [sessionText, cleanNote].filter(Boolean).join(' | ');
    }

    function derivePlanillaFromSessions(sessions) {
      return derivePlanillaMetrics(sessions, '').status;
    }

    function derivePlanillaMetrics(sessions, fallbackStatus) {
      const values = Object.keys(sessions || {}).map(function(key) {
        return normalizeSessionStatus(sessions[key]);
      }).filter(Boolean);
      const evaluable = values.filter(function(status) { return status !== 'A'; });
      if (!evaluable.length) {
        return {
          note: '',
          noteText: '—',
          status: normalizeStatus(fallbackStatus),
          sessionCount: 0
        };
      }
      const points = evaluable.reduce(function(total, status) {
        return total + Number(SESSION_NOTE_VALUES[status] || 0);
      }, 0);
      const average = points / evaluable.length;
      const note = Math.max(1, Math.min(7, 1 + (average * 2)));
      return {
        note: note,
        noteText: note.toFixed(1),
        status: statusFromAveragePoints(average),
        sessionCount: evaluable.length
      };
    }

    function statusFromAveragePoints(average) {
      if (!Number.isFinite(average)) return '';
      if (average >= 2.5) return 'L';
      if (average >= 1.5) return 'ML';
      if (average > 0) return 'PL';
      return 'NL';
    }

    function dominantStatus(statuses) {
      const counts = { L: 0, ML: 0, PL: 0, NL: 0 };
      (statuses || []).forEach(function(status) {
        const clean = normalizeStatus(status);
        if (clean) counts[clean] += 1;
      });
      return STATUS_ORDER.slice().sort(function(left, right) {
        return counts[right] - counts[left];
      })[0];
    }

    function showToast(message, isError) {
      toast.textContent = message;
      toast.className = 'toast show ' + (isError ? 'err' : 'ok');
      window.clearTimeout(showToast._timer);
      showToast._timer = window.setTimeout(function() {
        toast.classList.remove('show');
      }, 2800);
    }

    function formatDate(value) {
      try {
        return new Date(Number(value)).toLocaleString('es-CL', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });
      } catch (error) {
        return 'fecha invalida';
      }
    }

    function courseLabel(course) {
      if (!course) return 'Sin curso';
      const match = String(course).match(/^(\d)([A-Z])-TP$/);
      if (!match) return String(course);
      return match[1] + '°' + match[2] + ' TP';
    }

    function compactDate() {
      const now = new Date();
      return [now.getFullYear(), pad(now.getMonth() + 1), pad(now.getDate()), pad(now.getHours()), pad(now.getMinutes())].join('');
    }

    function pad(value) {
      return String(value).padStart(2, '0');
    }

    function downloadFile(name, text, type) {
      const blob = new Blob([text], { type: type });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = name;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
    }

    function escapeHtml(value) {
      return String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }
  </script>
</body>
</html>