{
  "cleanUrls": false,
  "regions": ["iad1"],
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "redirects": [
    {
      "source": "/prueba",
      "destination": "/lecturas/prueba.html",
      "permanent": false
    },
    {
      "source": "/prueba.html",
      "destination": "/lecturas/prueba.html",
      "permanent": false
    },
    {
      "source": "/perfil",
      "destination": "/lecturas/perfil.html",
      "permanent": false
    },
    {
      "source": "/perfil.html",
      "destination": "/lecturas/perfil.html",
      "permanent": false
    },
    {
      "source": "/lecturas/dashboard",
      "destination": "/lecturas/dashboard.html",
      "permanent": false
    },
    {
      "source": "/lecturas/admin",
      "destination": "/lecturas/adminprofe/",
      "permanent": false
    },
    {
      "source": "/lecturas/admin.html",
      "destination": "/lecturas/adminprofe/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/estudiantes/adminprofe/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/estudiantes/sesion(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/lecturas/adminprofe/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/lecturas/prueba(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/np(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}