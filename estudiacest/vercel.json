{
  "cleanUrls": false,
  "outputDirectory": ".",
  "regions": ["iad1"],
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "redirects": [
    {
      "source": "/favicon.ico",
      "destination": "/estudiantes/assets/logo-cest.png",
      "permanent": false
    },
    {
      "source": "/NM3",
      "destination": "/nm3/",
      "permanent": false
    },
    {
      "source": "/NM3/",
      "destination": "/nm3/",
      "permanent": false
    },
    {
      "source": "/prueba",
      "destination": "/lecturas/prueba.html",
      "permanent": false
    },
    {
      "source": "/prueba.html",
      "destination": "/lecturas/prueba.html",
      "permanent": false
    },
    {
      "source": "/perfil",
      "destination": "/lecturas/perfil.html",
      "permanent": false
    },
    {
      "source": "/perfil.html",
      "destination": "/lecturas/perfil.html",
      "permanent": false
    },
    {
      "source": "/gato",
      "destination": "/gato/index.html",
      "permanent": false
    },
    {
      "source": "/gato/",
      "destination": "/gato/index.html",
      "permanent": false
    },
    {
      "source": "/lecturas/dashboard",
      "destination": "/lecturas/dashboard.html",
      "permanent": false
    },
    {
      "source": "/lecturas/admin",
      "destination": "/lecturas/adminprofe/",
      "permanent": false
    },
    {
      "source": "/lecturas/admin.html",
      "destination": "/lecturas/adminprofe/",
      "permanent": false
    },
    {
      "source": "/PAES",
      "destination": "/paes/",
      "permanent": false
    },
    {
      "source": "/PAES/",
      "destination": "/paes/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/3atp",
      "destination": "/3atp/index.html"
    },
    {
      "source": "/3atp/",
      "destination": "/3atp/index.html"
    },
    {
      "source": "/paes",
      "destination": "/paes/index.html"
    },
    {
      "source": "/paes/",
      "destination": "/paes/index.html"
    },
    {
      "source": "/paes/guias",
      "destination": "/paes/guias.html"
    },
    {
      "source": "/paes/guias/",
      "destination": "/paes/guias.html"
    },
    {
      "source": "/paes/admin",
      "destination": "/paes/admin/index.html"
    },
    {
      "source": "/paes/admin/",
      "destination": "/paes/admin/index.html"
    },
    {
      "source": "/revision-triptico",
      "destination": "/revision-triptico/index.html"
    },
    {
      "source": "/revision-triptico/",
      "destination": "/revision-triptico/index.html"
    }
  ],
  "headers": [
    {
      "source": "/estudiantes/adminprofe/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/estudiantes/sesion(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/lecturas/adminprofe/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/lecturas/prueba(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/np(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}