---
layout: layout-evaluaciones.njk
title: "Admin · Accesos ECEP"
head: '<link rel="stylesheet" href="/css/ecep-portal.css?v=36"><style>html.ecg body{visibility:hidden}</style><script>document.documentElement.classList.add("ecg");window.ECEP_PAGE="admin";</script>'
scripts: '<script src="/js/ecep-auth.js?v=38"></script>'
---
<div class="ecp ecp-dash">
  <header class="ecp-topbar">
    <div class="in">
      <a class="ecp-logo" href="/evaluaciones/"><span class="mark"><i class="bi bi-shield-lock-fill"></i></span> <span>Admin <b>ECEP</b></span></a>
      <div class="ecp-user">
        <div class="who"><b data-user-name>Admin</b><small data-user-email></small></div>
        <div class="ecp-ava" data-user-initial>·</div>
        <button class="ecp-logout" onclick="ecepLogout()"><i class="bi bi-box-arrow-right"></i> Salir</button>
      </div>
    </div>
  </header>

  <main class="ecp-main">
    <div class="ecp-head">
      <h1 class="ecp-hello">Accesos por dossier</h1>
      <p class="ecp-lede">Activa el acceso de cada docente al dossier que pagó. El cambio es inmediato (el docente solo debe recargar).</p>
    </div>

    <div id="adm-stats" style="display:none;margin:0 0 22px">
      <div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:12px">
        <div class="adm-kpi" style="flex:1;min-width:150px;background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px 16px">
          <div style="font-size:12px;color:#64748b;font-weight:600">Docentes registrados</div>
          <div id="kpi-users" style="font:800 26px Poppins,sans-serif;color:#0f172a">—</div>
        </div>
        <div class="adm-kpi" style="flex:1;min-width:150px;background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px 16px">
          <div style="font-size:12px;color:#64748b;font-weight:600">Accesos pagados</div>
          <div id="kpi-accesos" style="font:800 26px Poppins,sans-serif;color:#0f172a">—</div>
        </div>
        <div class="adm-kpi" style="flex:1;min-width:150px;background:#ecfdf5;border:1px solid #a7f3d0;border-radius:14px;padding:14px 16px">
          <div style="font-size:12px;color:#047857;font-weight:600">Ingreso estimado</div>
          <div id="kpi-ingreso" style="font:800 26px Poppins,sans-serif;color:#065f46">—</div>
        </div>
        <div class="adm-kpi" style="flex:1;min-width:150px;background:#fffbeb;border:1px solid #fde68a;border-radius:14px;padding:14px 16px">
          <div style="font-size:12px;color:#b45309;font-weight:600">Regalados (no son venta)</div>
          <div id="kpi-regalados" style="font:800 26px Poppins,sans-serif;color:#92400e">—</div>
        </div>
      </div>
      <div id="kpi-pordossier" style="display:flex;flex-wrap:wrap;gap:8px"></div>
    </div>

    <div style="margin:0 0 16px"><input id="adm-q" type="search" placeholder="Buscar por correo o nombre…" style="width:100%;max-width:420px;padding:11px 14px;border:1px solid #e2e8f0;border-radius:11px;font-size:14px"></div>

    <div id="adm-status" style="color:#64748b;font-size:14px;margin-bottom:12px">Cargando usuarios…</div>
    <div id="adm-list" style="display:flex;flex-direction:column;gap:12px"></div>
  </main>
</div>

<script>
window.ecepAdminInit = function (firebase) {
  var DB = firebase.database();
  // [id, abreviatura, grupo, nombre completo]
  var DOSSIERS = [
    ['generalista','Generalista','Básica','Generalista'],
    ['lenguaje','Lenguaje','Básica','Lenguaje y Comunicación'],
    ['matematica','Matemática','Básica','Matemática'],
    ['historia','Historia','Básica','Historia y Geografía'],
    ['ciencias','Ciencias','Básica','Ciencias Naturales'],
    ['ingles','Inglés·B','Básica','Inglés'],
    ['ef-basica','EdFís·B','Básica','Educación Física y Salud'],
    ['religion','Relig·B','Básica','Religión Católica'],
    ['tecnologia','Tecno·B','Básica','Tecnología'],
    ['musica-basica','Música·B','Básica','Música'],
    ['artes-basica','Artes·B','Básica','Artes Visuales'],
    ['parvularia','Parvularia','Parvularia','Educación Parvularia'],
    ['especial-dea','Esp·DEA','Especial','Dificultades del Aprendizaje (DEA)'],
    ['especial-di','Esp·DI','Especial','Discapacidad Intelectual (DI)'],
    ['especial-tea','Esp·TEA','Especial','Trastorno del Espectro Autista (TEA)'],
    ['especial-tel','Esp·TEL','Especial','Trastorno del Lenguaje (TEL)'],
    ['media-lengua','M·Lengua','Media','Lengua y Literatura'],
    ['media-matematica','M·Mate','Media','Matemática'],
    ['media-biologia','M·Bio','Media','Biología'],
    ['media-historia','M·Hist','Media','Historia y Geografía'],
    ['media-fisica','M·Fís','Media','Física'],
    ['media-quimica','M·Quím','Media','Química'],
    ['media-ingles','Inglés·M','Media','Inglés'],
    ['media-musica','Música·M','Media','Música'],
    ['media-artes-visuales','Artes·M','Media','Artes Visuales'],
    ['media-educacion-fisica','EdFís·M','Media','Educación Física y Salud'],
    ['media-filosofia','Filos·M','Media','Filosofía']
  ];
  var GRUPOS = ['Básica','Parvularia','Especial','Media'];
  var statusEl = document.getElementById('adm-status');
  var lista = document.getElementById('adm-list');
  var usuarios = {}, accesos = {}, regalos = {};

  function toggle(uid, did, on, btn) {
    var ref = DB.ref('ecep_accesos/' + uid + '/' + did);
    btn.disabled = true;
    (on ? ref.set(true) : ref.remove()).then(function () {
      accesos[uid] = accesos[uid] || {};
      if (on) accesos[uid][did] = true; else delete accesos[uid][did];
      btn.disabled = false; paintChip(btn, on); renderStats(); refreshContador(uid);
    }).catch(function (e) { btn.disabled = false; alert('Error: ' + (e && e.message)); });
  }
  function paintChip(btn, on) {
    var name = btn.dataset.name || '';
    btn.innerHTML = (on ? '<i class="bi bi-check-circle-fill"></i> ' : '<i class="bi bi-plus-circle"></i> ') + name;
    btn.style.background = on ? '#dcfce7' : '#fff';
    btn.style.borderColor = on ? '#86efac' : '#e2e8f0';
    btn.style.color = on ? '#15803d' : '#475569';
    btn.style.fontWeight = on ? '700' : '500';
    btn.dataset.on = on ? '1' : '0';
  }
  function nActivos(uid) {
    var n = 0; DOSSIERS.forEach(function (d) { if (accesos[uid] && accesos[uid][d[0]] === true) n++; }); return n;
  }
  function refreshContador(uid) {
    var el = document.getElementById('cnt-' + uid);
    if (el) { var n = nActivos(uid); el.textContent = n + (n === 1 ? ' acceso' : ' accesos'); el.style.color = n ? '#15803d' : '#94a3b8'; }
  }
  function renderStats() {
    var nUsers = Object.keys(usuarios).length;
    var perD = {}, total = 0, regalados = 0;   // total = solo PAGADOS (los regalos no son venta)
    DOSSIERS.forEach(function (d) { perD[d[0]] = 0; });
    Object.keys(accesos).forEach(function (uid) {
      var esRegalo = !!regalos[uid];           // usuario marcado en ecep_regalos = acceso de cortesía
      DOSSIERS.forEach(function (d) {
        if (accesos[uid] && accesos[uid][d[0]] === true) {
          if (esRegalo) { regalados++; } else { perD[d[0]]++; total++; }
        }
      });
    });
    document.getElementById('kpi-users').textContent = nUsers;
    document.getElementById('kpi-accesos').textContent = total;
    document.getElementById('kpi-ingreso').textContent = '$' + (total * 10000).toLocaleString('es-CL');
    var kr = document.getElementById('kpi-regalados'); if (kr) kr.textContent = regalados;
    document.getElementById('kpi-pordossier').innerHTML = DOSSIERS.map(function (d) {
      return '<span style="background:#fff;border:1px solid #e2e8f0;border-radius:999px;padding:6px 12px;font-size:13px;color:#334155"><b>' + perD[d[0]] + '</b> · ' + d[1] + '</span>';
    }).join('');
    document.getElementById('adm-stats').style.display = '';
  }
  function borrarUsuario(uid, nombre) {
    if (!confirm('¿Eliminar a "' + nombre + '" del registro?\n\nSe borra su registro y TODOS sus accesos pagados. Esta acción no se puede deshacer.\n\nNota: si la persona vuelve a iniciar sesión, se registrará de nuevo (sin accesos).')) return;
    Promise.all([
      DB.ref('ecep_usuarios/' + uid).remove(),
      DB.ref('ecep_accesos/' + uid).remove()
    ]).then(function () {
      delete usuarios[uid]; delete accesos[uid];
      render(); renderStats();
    }).catch(function (e) { alert('No se pudo eliminar: ' + (e && e.message)); });
  }

  function render() {
    var q = (document.getElementById('adm-q').value || '').toLowerCase();
    var uids = Object.keys(usuarios).sort(function (a, b) {
      return (usuarios[a].email || '').localeCompare(usuarios[b].email || '');
    });
    lista.innerHTML = '';
    var shown = 0;
    uids.forEach(function (uid) {
      var u = usuarios[uid];
      var hay = ((u.email || '') + ' ' + (u.nombre || '')).toLowerCase();
      if (q && hay.indexOf(q) < 0) return;
      shown++;
      var n = nActivos(uid);
      var card = document.createElement('div');
      card.style.cssText = 'background:#fff;border:1px solid #e2e8f0;border-radius:14px;overflow:hidden';

      var head = document.createElement('div');
      head.style.cssText = 'display:flex;align-items:center;gap:10px;flex-wrap:wrap;padding:13px 15px';
      head.innerHTML =
        '<div style="flex:1;min-width:150px">' +
          '<b style="font-size:15px">' + (u.nombre || '—') + '</b>' +
          (regalos[uid] ? ' <span style="display:inline-block;background:#fffbeb;border:1px solid #fde68a;color:#b45309;border-radius:999px;padding:2px 9px;font-size:11px;font-weight:700;vertical-align:middle">🎁 Regalo</span>' : '') +
          '<div style="font-size:12.5px;color:#64748b">' + (u.email || uid) + '</div>' +
        '</div>' +
        '<span id="cnt-' + uid + '" style="font-size:13px;font-weight:700;white-space:nowrap;color:' + (n ? '#15803d' : '#94a3b8') + '">' + n + (n === 1 ? ' acceso' : ' accesos') + '</span>';
      var acts = document.createElement('div');
      acts.style.cssText = 'display:flex;gap:7px';
      var gest = document.createElement('button');
      gest.innerHTML = '<i class="bi bi-sliders"></i> Gestionar accesos';
      gest.style.cssText = 'display:inline-flex;align-items:center;gap:6px;border:1px solid #cbd5e1;background:#f8fafc;color:#0f172a;border-radius:9px;padding:8px 13px;font-size:13px;font-weight:600;cursor:pointer';
      var del = document.createElement('button');
      del.innerHTML = '<i class="bi bi-trash"></i>';
      del.title = 'Eliminar usuario del registro y sus accesos';
      del.style.cssText = 'border:1px solid #fecaca;background:#fff;color:#dc2626;border-radius:9px;padding:8px 12px;font-size:13px;cursor:pointer';
      del.onclick = function () { borrarUsuario(uid, u.nombre || u.email || uid); };
      acts.appendChild(gest); acts.appendChild(del);
      head.appendChild(acts);
      card.appendChild(head);

      var panel = document.createElement('div');
      panel.style.cssText = 'display:none;border-top:1px solid #f1f5f9;padding:12px 15px 15px;background:#fcfdfe';
      GRUPOS.forEach(function (g) {
        var ds = DOSSIERS.filter(function (d) { return d[2] === g; });
        if (!ds.length) return;
        var sec = document.createElement('div'); sec.style.cssText = 'margin-bottom:12px';
        var gh = document.createElement('div');
        gh.textContent = g;
        gh.style.cssText = 'font-size:11.5px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:#94a3b8;margin:2px 0 8px';
        sec.appendChild(gh);
        var wrap = document.createElement('div'); wrap.style.cssText = 'display:flex;flex-wrap:wrap;gap:7px';
        ds.forEach(function (d) {
          var on = !!(accesos[uid] && accesos[uid][d[0]] === true);
          var btn = document.createElement('button');
          btn.dataset.name = d[3]; btn.dataset.did = d[0];
          btn.style.cssText = 'display:inline-flex;align-items:center;gap:6px;border:1px solid #e2e8f0;border-radius:999px;padding:7px 13px;font-size:13px;cursor:pointer';
          paintChip(btn, on);
          btn.onclick = function () { toggle(uid, d[0], btn.dataset.on !== '1', btn); };
          wrap.appendChild(btn);
        });
        sec.appendChild(wrap); panel.appendChild(sec);
      });
      card.appendChild(panel);
      gest.onclick = function () {
        var open = panel.style.display !== 'none';
        panel.style.display = open ? 'none' : 'block';
        gest.innerHTML = open ? '<i class="bi bi-sliders"></i> Gestionar accesos' : '<i class="bi bi-chevron-up"></i> Ocultar accesos';
      };
      lista.appendChild(card);
    });
    statusEl.textContent = shown + ' docente(s) · toca «Gestionar accesos» para activar el dossier que pagó.';
  }

  Promise.all([
    DB.ref('ecep_usuarios').once('value'),
    DB.ref('ecep_accesos').once('value'),
    DB.ref('ecep_regalos').once('value')
  ]).then(function (snaps) {
    usuarios = snaps[0].val() || {};
    accesos = snaps[1].val() || {};
    regalos = snaps[2].val() || {};
    renderStats();
    if (!Object.keys(usuarios).length) { statusEl.textContent = 'Aún no hay docentes registrados (ingresan al iniciar sesión con Google).'; return; }
    render();
    document.getElementById('adm-q').addEventListener('input', render);
  }).catch(function (e) { statusEl.textContent = 'Error al cargar: ' + (e && e.message); });
};
</script>
