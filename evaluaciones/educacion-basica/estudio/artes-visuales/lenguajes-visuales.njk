              <rect x="722" y="170" width="60" height="60" fill="none" stroke="#0f172a" stroke-width="2.5"/>
              <line x1="752" y1="200" x2="752" y2="200" stroke="#0f172a" stroke-width="3" stroke-linecap="round"/>
              <circle cx="752" cy="200" r="3" fill="#0f172a"/>
              <text x="752" y="290" text-anchor="middle" font-family="Inter,system-ui" font-size="11.5" fill="#475569">lo esencial: pocas</text>
              <text x="752" y="306" text-anchor="middle" font-family="Inter,system-ui" font-size="11.5" fill="#475569">formas, pocos colores</text>
