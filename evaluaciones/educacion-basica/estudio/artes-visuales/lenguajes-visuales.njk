              <line x1="40" y1="62" x2="820" y2="62" stroke="#db2777" stroke-width="2.5"/>
              <circle cx="115" cy="62" r="5" fill="#db2777"/><circle cx="330" cy="62" r="5" fill="#db2777"/>
              <circle cx="545" cy="62" r="5" fill="#db2777"/><circle cx="755" cy="62" r="5" fill="#db2777"/>
