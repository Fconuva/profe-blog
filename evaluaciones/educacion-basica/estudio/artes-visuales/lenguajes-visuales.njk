              <!-- ART NOUVEAU -->
              <rect x="22" y="86" width="186" height="270" rx="14" fill="#fdf2f8" stroke="#db2777" stroke-width="1.5"/>
              <text x="115" y="112" text-anchor="middle" font-family="Inter,system-ui" font-size="13.5" font-weight="700" fill="#9d174d">ART NOUVEAU</text>
              <path d="M70 250 Q70 180 115 160 Q160 180 160 250" fill="none" stroke="#0f172a" stroke-width="2.5"/>
