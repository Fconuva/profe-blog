              <!-- LH spike at ovulation -->
              <path d="M380 225 l18 -55 l18 55" fill="none" stroke="#b45309" stroke-width="2.5"/>
              <text x="430" y="172" font-family="Inter, sans-serif" font-size="10.5" fill="#b45309" font-weight="700">LH (pico → ovula)</text>
              <!-- progesterona dome after ovulation -->
              <path d="M410 225 q90 -75 170 0 q15 18 30 20" fill="none" stroke="#9d174e" stroke-width="2.5"/>
              <text x="610" y="160" font-family="Inter, sans-serif" font-size="10.5" fill="#9d174e" font-weight="700">Progesterona</text>
              <!-- 3. ciclo uterino band (endometrio thickness) -->
              <text x="60" y="263" font-family="Inter, sans-serif" font-size="12" fill="#065f46" font-weight="700">Endometrio</text>
              <path d="M60 305 L130 305 L130 290 Q260 250 400 248 Q540 246 560 248 L560 290 L720 290 L720 305 Z" fill="#fce7f3" stroke="#9d174e" stroke-width="1.2"/>
