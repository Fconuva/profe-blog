                <marker id="ef-fl" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse"><path d="M0,0 L10,5 L0,10 z" fill="#15803d"/></marker>
              </defs>
              <rect x="0" y="0" width="560" height="230" fill="#ffffff"/>
              <text x="280" y="28" text-anchor="middle" font-size="16" font-weight="700" fill="#0f172a">De pensar el gesto a hacerlo sin pensar</text>
              <rect x="22"  y="58" width="150" height="120" rx="12" fill="#dcfce7" stroke="#15803d" stroke-width="2"/>
              <text x="97" y="88"  text-anchor="middle" font-size="12.5" font-weight="800" fill="#166534">COGNOSCITIVA</text>
              <text x="97" y="112" text-anchor="middle" font-size="11" fill="#14532d">entiende qué</text>
              <text x="97" y="128" text-anchor="middle" font-size="11" fill="#14532d">hacer; torpe</text>
              <text x="97" y="156" text-anchor="middle" font-size="10.5" fill="#14532d" font-style="italic">modelos y</text>
              <text x="97" y="170" text-anchor="middle" font-size="10.5" fill="#14532d" font-style="italic">demostración</text>
              <rect x="205" y="58" width="150" height="120" rx="12" fill="#bbf7d0" stroke="#15803d" stroke-width="2"/>
