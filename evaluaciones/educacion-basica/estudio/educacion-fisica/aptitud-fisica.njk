              <text x="463" y="112" text-anchor="middle" font-size="11" fill="#14532d">automático;</text>
              <text x="463" y="128" text-anchor="middle" font-size="11" fill="#14532d">sin pensarlo</text>
              <text x="463" y="156" text-anchor="middle" font-size="10.5" fill="#14532d" font-style="italic">aplicar al</text>
              <text x="463" y="170" text-anchor="middle" font-size="10.5" fill="#14532d" font-style="italic">juego real</text>
              <line x1="174" y1="118" x2="203" y2="118" stroke="#15803d" stroke-width="2.5" marker-end="url(#ef-fl)"/>
              <line x1="357" y1="118" x2="386" y2="118" stroke="#15803d" stroke-width="2.5" marker-end="url(#ef-fl)"/>
