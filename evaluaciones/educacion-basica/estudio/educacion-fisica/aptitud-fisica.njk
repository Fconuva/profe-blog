              <text x="280" y="112" text-anchor="middle" font-size="11" fill="#14532d">practica y</text>
              <text x="280" y="128" text-anchor="middle" font-size="11" fill="#14532d">afina; fluido</text>
              <text x="280" y="156" text-anchor="middle" font-size="10.5" fill="#14532d" font-style="italic">retroalimentación</text>
              <text x="280" y="170" text-anchor="middle" font-size="10.5" fill="#14532d" font-style="italic">precisa</text>
              <rect x="388" y="58" width="150" height="120" rx="12" fill="#86efac" stroke="#15803d" stroke-width="2"/>
