                <text x="654" y="268" text-anchor="middle" font-size="11">libertades públicas</text>
                <!-- abajo -->
                <rect x="270" y="298" width="220" height="42" rx="9" fill="#fef3c7" stroke="#f1c473"/>
                <text x="380" y="316" text-anchor="middle" font-weight="700" font-size="12">Participación</text>
                <text x="380" y="332" text-anchor="middle" font-size="11">ciudadana</text>
                <!-- izq-abajo -->
                <rect x="8" y="234" width="196" height="42" rx="9" fill="#fef3c7" stroke="#f1c473"/>
