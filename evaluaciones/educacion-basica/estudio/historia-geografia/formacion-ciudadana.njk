                <line x1="319" y1="197" x2="160" y2="248"/>
                <line x1="319" y1="143" x2="160" y2="92"/>
              </g>
              <g font-size="11.5" fill="#3a2a12">
                <!-- arriba -->
                <rect x="270" y="22" width="220" height="42" rx="9" fill="#fef3c7" stroke="#f1c473"/>
                <text x="380" y="40" text-anchor="middle" font-weight="700" font-size="12">Elecciones libres</text>
