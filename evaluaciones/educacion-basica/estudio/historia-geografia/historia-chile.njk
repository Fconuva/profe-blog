              <line x1="24" y1="120" x2="524" y2="120" stroke="#b45309" stroke-width="3" marker-end="url(#flecha-terr)"/>
              <text x="540" y="124" text-anchor="end" font-size="11" fill="#92400e">s. XIX</text>

              <!-- hitos: alternando arriba/abajo -->
              <!-- 1818 -->
              <circle cx="55" cy="120" r="5" fill="#b45309"/>
              <line x1="55" y1="120" x2="55" y2="92" stroke="#b45309" stroke-width="1.5"/>
