              <!-- puntos destacados -7 (x=72) y -2 (x=232) -->
              <circle cx="72" cy="120" r="6" fill="#0369a1"/><text x="72" y="100" text-anchor="middle" font-size="13" font-weight="700" fill="#075985">−7</text>
