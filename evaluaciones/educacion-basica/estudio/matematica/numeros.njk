                </marker>
                <marker id="flecha-sentido" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                  <path d="M0,0 L10,5 L0,10 z" fill="#334155"/>
                </marker>
              </defs>
              <rect x="0" y="0" width="560" height="230" fill="#ffffff"/>

              <!-- arco que une -7 y -2 -->
              <path d="M 70 96 Q 175 50 280 96" fill="none" stroke="#0369a1" stroke-width="2" stroke-linecap="round"/>
              <text x="175" y="58" text-anchor="middle" font-size="14" font-weight="700" fill="#075985">−2 &gt; −7</text>

              <!-- la recta -->
              <line x1="24" y1="120" x2="536" y2="120" stroke="#0369a1" stroke-width="2" stroke-linecap="round" marker-start="url(#flecha-recta)" marker-end="url(#flecha-recta)"/>

              <!-- marcas y rótulos: x de -8..8 cada 32px desde x=40 -->
              <g fill="#334155" font-size="13" text-anchor="middle">
                <line x1="40"  y1="114" x2="40"  y2="126" stroke="#cbd5e1" stroke-width="2"/><text x="40"  y="144">−8</text>
                <line x1="72"  y1="114" x2="72"  y2="126" stroke="#cbd5e1" stroke-width="2"/>
                <line x1="104" y1="114" x2="104" y2="126" stroke="#cbd5e1" stroke-width="2"/><text x="104" y="144">−6</text>
