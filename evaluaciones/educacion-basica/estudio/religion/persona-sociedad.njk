                <text x="115" y="97" text-anchor="middle" font-size="10" fill="#475569">vive en este mundo</text>
                <rect x="370" y="60" width="150" height="46" rx="9" fill="#f1f5f9" stroke="#64748b" stroke-width="1.5"/>
