              <rect x="0" y="0" width="860" height="250" fill="#ffffff"/>
              <text x="430" y="32" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="20" font-weight="700" fill="#0f172a">Fases de elaboración de un producto tecnológico tangible</text>
              <text x="430" y="56" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="14" fill="#475569">El orden es fijo: primero preparar, luego ejecutar y, al final, afinar</text>
              <g font-family="Inter,system-ui,sans-serif">
                <rect x="28"  y="86" width="172" height="96" rx="12" fill="#e2e8f0" stroke="#475569" stroke-width="2"/>
                <circle cx="58" cy="116" r="15" fill="#475569"/><text x="58" y="121" text-anchor="middle" font-size="14" font-weight="800" fill="#fff">1</text>
                <text x="120" y="120" text-anchor="middle" font-size="14.5" font-weight="700" fill="#0f172a">Preparación</text>
                <text x="114" y="148" text-anchor="middle" font-size="12" fill="#334155">medir, marcar,</text>
                <text x="114" y="165" text-anchor="middle" font-size="12" fill="#334155">trazar las piezas</text>

                <rect x="244" y="86" width="172" height="96" rx="12" fill="#e2e8f0" stroke="#475569" stroke-width="2"/>
                <circle cx="274" cy="116" r="15" fill="#475569"/><text x="274" y="121" text-anchor="middle" font-size="14" font-weight="800" fill="#fff">2</text>
                <text x="336" y="120" text-anchor="middle" font-size="14.5" font-weight="700" fill="#0f172a">Corte</text>
                <text x="330" y="148" text-anchor="middle" font-size="12" fill="#334155">serruchar,</text>
                <text x="330" y="165" text-anchor="middle" font-size="12" fill="#334155">recortar, tijeretear</text>

                <rect x="460" y="86" width="172" height="96" rx="12" fill="#e2e8f0" stroke="#475569" stroke-width="2"/>
                <circle cx="490" cy="116" r="15" fill="#475569"/><text x="490" y="121" text-anchor="middle" font-size="14" font-weight="800" fill="#fff">3</text>
                <text x="552" y="120" text-anchor="middle" font-size="14.5" font-weight="700" fill="#0f172a">Unión</text>
                <text x="546" y="148" text-anchor="middle" font-size="12" fill="#334155">pegar, clavar,</text>
                <text x="546" y="165" text-anchor="middle" font-size="12" fill="#334155">atornillar, amarrar</text>

                <rect x="676" y="86" width="172" height="96" rx="12" fill="#475569" stroke="#334155" stroke-width="2"/>
                <circle cx="706" cy="116" r="15" fill="#fff"/><text x="706" y="121" text-anchor="middle" font-size="14" font-weight="800" fill="#475569">4</text>
                <text x="768" y="120" text-anchor="middle" font-size="14.5" font-weight="700" fill="#fff">Acabado</text>
                <text x="762" y="148" text-anchor="middle" font-size="12" fill="#e2e8f0">lijar, pintar,</text>
                <text x="762" y="165" text-anchor="middle" font-size="12" fill="#e2e8f0">barnizar, pulir</text>

                <line x1="200" y1="134" x2="242" y2="134" stroke="#475569" stroke-width="3" marker-end="url(#faseAr)"/>
                <line x1="416" y1="134" x2="458" y2="134" stroke="#475569" stroke-width="3" marker-end="url(#faseAr)"/>
