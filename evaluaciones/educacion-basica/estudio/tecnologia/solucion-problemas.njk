                  <text x="430" y="355" text-anchor="middle" font-size="10.5" fill="#475569">¿poco gasto?</text>

                  <rect x="196" y="296" width="124" height="42" rx="9" fill="#e2e8f0" stroke="#475569" stroke-width="1.6"/>
                  <text x="258" y="316" text-anchor="middle" font-size="11.5" font-weight="700" fill="#334155">Sustentabilidad</text>
                  <text x="258" y="331" text-anchor="middle" font-size="10.5" fill="#475569">¿y el planeta?</text>

                  <rect x="90" y="194" width="130" height="42" rx="9" fill="#e2e8f0" stroke="#475569" stroke-width="1.6"/>
