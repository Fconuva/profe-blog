                  <text x="602" y="331" text-anchor="middle" font-size="10.5" fill="#475569">¿cuánto cuesta?</text>

                  <rect x="368" y="320" width="124" height="42" rx="9" fill="#e2e8f0" stroke="#475569" stroke-width="1.6"/>
