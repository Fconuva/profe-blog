              <rect x="46" y="232" width="124" height="32" rx="7" fill="#fff" stroke="#7c3aed"/><text x="108" y="252" fill="#5b21b6" font-size="12" font-weight="700" text-anchor="middle">Sonido / letra</text>
              <rect x="46" y="184" width="124" height="32" rx="7" fill="#fff" stroke="#7c3aed"/><text x="108" y="204" fill="#5b21b6" font-size="12" font-weight="700" text-anchor="middle">Sílaba / palabra</text>
              <rect x="46" y="136" width="124" height="32" rx="7" fill="#fff" stroke="#7c3aed"/><text x="108" y="156" fill="#5b21b6" font-size="12" font-weight="700" text-anchor="middle">Texto</text>
