              <text x="108" y="190" fill="#7c3aed" font-size="11.5" font-style="italic" text-anchor="middle">preparar la mente</text>

              <rect x="214" y="56" width="172" height="158" rx="12" fill="#ede9fe" stroke="#7c3aed" stroke-width="2"/>
