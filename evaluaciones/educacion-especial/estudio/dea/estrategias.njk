              <!-- Pictórico -->
              <rect x="222" y="52" width="156" height="140" rx="12" fill="#faf5ff" stroke="#7c3aed" stroke-width="1.5"/>
              <text x="300" y="74" fill="#5b21b6" font-size="13" font-weight="700" text-anchor="middle">Pictórico</text>
