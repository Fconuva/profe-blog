                <rect x="358" y="266" width="150" height="36" rx="9" fill="#ede9fe" stroke="#7c3aed" stroke-width="1.6"/>
                <text x="433" y="289" fill="#5b21b6">Derechos</text>
              </g>

              <!-- conectores -->
              <g stroke="#c4b5fd" stroke-width="1.8">
                <line x1="160" y1="80" x2="240" y2="150"/>
