              <text x="280" y="193" fill="#ede9fe" font-size="13" font-weight="700" text-anchor="middle">de vida</text>

              <!-- 8 satélites -->
              <g font-size="11" font-weight="700" text-anchor="middle">
                <rect x="52" y="58" width="150" height="36" rx="9" fill="#ede9fe" stroke="#7c3aed" stroke-width="1.6"/>
