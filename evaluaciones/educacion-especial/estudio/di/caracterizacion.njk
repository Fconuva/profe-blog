              <text x="282" y="184" fill="#ede9fe" font-size="10.5" text-anchor="middle">el puente</text>

              <!-- resultado -->
              <circle cx="452" cy="170" r="64" fill="#ede9fe" stroke="#7c3aed" stroke-width="2.2"/>
              <text x="452" y="162" fill="#5b21b6" font-size="13" font-weight="700" text-anchor="middle">Funcionamiento</text>
              <text x="452" y="180" fill="#5b21b6" font-size="13" font-weight="700" text-anchor="middle">humano</text>

              <!-- flechas dimensiones -> apoyos -->
              <path d="M196 76 C 218 90 220 120 234 140" fill="none" stroke="#c4b5fd" stroke-width="2"/>
