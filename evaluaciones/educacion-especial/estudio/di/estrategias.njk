              <text x="153" y="222" fill="#64748b" font-size="11.5" font-style="italic" text-anchor="middle">se aprende solo en la sala;</text>
              <text x="153" y="240" fill="#64748b" font-size="11.5" font-style="italic" text-anchor="middle">no se usa en la vida</text>

              <!-- Funcional ecológico -->
              <rect x="316" y="52" width="262" height="206" rx="12" fill="#ede9fe" stroke="#7c3aed" stroke-width="2"/>
