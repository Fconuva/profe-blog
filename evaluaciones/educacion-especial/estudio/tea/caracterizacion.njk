              <!-- Nivel 3 -->
              <rect x="370" y="70" width="150" height="190" rx="10" fill="#7c3aed" stroke="#5b21b6" stroke-width="2"/>
              <text x="445" y="104" fill="#ffffff" font-size="15" font-weight="800" text-anchor="middle">Nivel 3</text>
              <text x="445" y="124" fill="#ffffff" font-size="11.5" font-weight="700" text-anchor="middle">Necesita ayuda</text>
              <text x="445" y="139" fill="#ffffff" font-size="11.5" font-weight="700" text-anchor="middle">muy notable</text>
