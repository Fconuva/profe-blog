              <text x="395" y="80" fill="#5b21b6" font-size="12" font-weight="700" text-anchor="middle">Pausas y</text>
              <text x="395" y="96" fill="#5b21b6" font-size="12" font-weight="700" text-anchor="middle">apoyos</text>
              <text x="395" y="134" fill="#334155" font-size="10.5" text-anchor="middle">audífonos,</text>
              <text x="395" y="150" fill="#334155" font-size="10.5" text-anchor="middle">descansos</text>
              <text x="395" y="166" fill="#334155" font-size="10.5" text-anchor="middle">anticipados</text>

