              <text x="371" y="110" fill="#64748b" font-size="10.5" text-anchor="middle">secuencia ordenada en el tiempo</text>

              <!-- peldaño 4 -->
              <rect x="372" y="40" width="194" height="28" rx="8" fill="#7c3aed" stroke="#5b21b6" stroke-width="1.8"/>
              <text x="469" y="59" fill="#fff" font-size="12" font-weight="700" text-anchor="middle">4 · Narración completa</text>

              <path d="M150 192 C 120 176 124 158 150 150" fill="none" stroke="#7c3aed" stroke-width="2.2" marker-end="url(#arrNar)"/>
              <path d="M266 140 C 236 124 240 106 266 98" fill="none" stroke="#7c3aed" stroke-width="2.2" marker-end="url(#arrNar)"/>
