              <text x="477" y="100" fill="#5b21b6" font-size="10.5" text-anchor="middle">Profesor(a) de aula</text>
              <text x="477" y="118" fill="#334155" font-size="10.5" text-anchor="middle">objetivos del curso</text>
              <text x="477" y="133" fill="#334155" font-size="10.5" text-anchor="middle">currículum común</text>

              <!-- Articulador -->
              <rect x="205" y="178" width="190" height="52" rx="12" fill="#7c3aed" stroke="#5b21b6" stroke-width="2"/>
              <text x="300" y="200" fill="#fff" font-size="12.5" font-weight="700" text-anchor="middle">Educador(a) diferencial</text>
              <text x="300" y="217" fill="#ede9fe" font-size="10.5" text-anchor="middle">articula en co-docencia</text>

              <!-- flechas de convergencia -->
              <path d="M123 144 L270 178" fill="none" stroke="#7c3aed" stroke-width="2.2" marker-end="url(#arrPlan)"/>
              <path d="M477 144 L330 178" fill="none" stroke="#7c3aed" stroke-width="2.2" marker-end="url(#arrPlan)"/>
              <path d="M218 101 L382 101" fill="none" stroke="#7c3aed" stroke-width="2" stroke-dasharray="5 4" marker-end="url(#arrPlan)" marker-start="url(#arrPlan)"/>
