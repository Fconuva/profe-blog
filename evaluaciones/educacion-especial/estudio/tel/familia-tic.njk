              <text x="123" y="100" fill="#5b21b6" font-size="10.5" text-anchor="middle">Fonoaudiólogo(a)</text>
              <text x="123" y="118" fill="#334155" font-size="10.5" text-anchor="middle">fonología · morfosintaxis</text>
              <text x="123" y="133" fill="#334155" font-size="10.5" text-anchor="middle">semántica · pragmática</text>

