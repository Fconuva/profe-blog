              <text x="300" y="32" fill="#5b21b6" font-size="17" font-weight="700" text-anchor="middle">Un mismo estudiante, dos miradas</text>
              <!-- déficit -->
              <rect x="26" y="56" width="244" height="178" rx="10" fill="#f1f5f9" stroke="#94a3b8" stroke-width="1.5"/>
              <text x="148" y="82" fill="#334155" font-size="14" font-weight="700" text-anchor="middle">Modelo del déficit</text>
