                <text x="284" y="135" text-anchor="middle" font-size="10.5" fill="#831843">telar</text>
                <text x="284" y="170" text-anchor="middle" font-size="10" fill="#9d174d" font-style="italic">andino</text>
                <rect x="344" y="58" width="100" height="160" rx="11" fill="#fce7f3" stroke="#db2777" stroke-width="2"/>
