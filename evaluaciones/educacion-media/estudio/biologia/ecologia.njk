              <line x1="70" y1="290" x2="530" y2="290" stroke="#334155" stroke-width="2"/>
              <line x1="70" y1="290" x2="70" y2="55" stroke="#334155" stroke-width="2"/>
              <text x="300" y="322" text-anchor="middle" font-size="13" fill="#334155">Tiempo</text>
              <text x="26" y="175" text-anchor="middle" font-size="13" fill="#334155" transform="rotate(-90 26 175)">N&#176; de individuos</text>
              <!-- Capacidad de carga K: línea punteada en y=110 -->
              <line x1="70" y1="110" x2="530" y2="110" stroke="#64748b" stroke-width="1.6" stroke-dasharray="7 5"/>
              <text x="525" y="103" text-anchor="end" font-size="12.5" font-weight="700" fill="#475569">Capacidad de carga (K)</text>
              <!-- Curva en J (exponencial), verde claro #047857 -->
              <path d="M70,288 C170,284 250,276 320,250 C380,228 420,180 450,90 C462,55 468,40 470,30" fill="none" stroke="#047857" stroke-width="3" stroke-linecap="round"/>
