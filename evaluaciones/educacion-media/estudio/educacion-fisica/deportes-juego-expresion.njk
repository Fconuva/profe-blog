              <text x="217" y="106" text-anchor="middle" font-size="10.5" fill="#14532d">decisión en</text>
              <text x="217" y="122" text-anchor="middle" font-size="10.5" fill="#14532d">la jugada</text>
              <text x="217" y="146" text-anchor="middle" font-size="10" fill="#475569" font-style="italic">a quién paso</text>
              <rect x="290" y="50" width="125" height="120" rx="11" fill="#dcfce7" stroke="#15803d" stroke-width="2"/>
              <text x="352" y="78" text-anchor="middle" font-size="12.5" font-weight="800" fill="#166534">ESTRATEGIA</text>
              <text x="352" y="106" text-anchor="middle" font-size="10.5" fill="#14532d">plan general</text>
              <text x="352" y="122" text-anchor="middle" font-size="10.5" fill="#14532d">antes del juego</text>
              <text x="352" y="146" text-anchor="middle" font-size="10" fill="#475569" font-style="italic">cómo plantear</text>
              <rect x="425" y="50" width="125" height="120" rx="11" fill="#dcfce7" stroke="#15803d" stroke-width="2"/>
