              <text x="82" y="78" text-anchor="middle" font-size="12.5" font-weight="800" fill="#166534">TÉCNICA</text>
              <text x="82" y="106" text-anchor="middle" font-size="10.5" fill="#14532d">el gesto</text>
              <text x="82" y="122" text-anchor="middle" font-size="10.5" fill="#14532d">correcto</text>
              <text x="82" y="146" text-anchor="middle" font-size="10" fill="#475569" font-style="italic">golpe, pase</text>
              <rect x="155" y="50" width="125" height="120" rx="11" fill="#dcfce7" stroke="#15803d" stroke-width="2"/>
