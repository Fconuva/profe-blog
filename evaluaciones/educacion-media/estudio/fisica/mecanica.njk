              </g>
              <!-- ===== MRU: velocidad-tiempo (abajo izq) ===== -->
              <g>
                <line x1="40" y1="290" x2="40" y2="195" stroke="#334155" stroke-width="1.6"/>
                <line x1="40" y1="290" x2="270" y2="290" stroke="#334155" stroke-width="1.6"/>
                <text x="34" y="203" text-anchor="end" font-size="11" fill="#334155">v</text>
                <text x="272" y="302" font-size="11" fill="#334155">t</text>
