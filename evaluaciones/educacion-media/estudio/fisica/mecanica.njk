              <text x="465" y="22" text-anchor="middle" font-size="14" font-weight="800" fill="#155e75">MRUA · aceleración constante</text>

              <!-- ===== MRU: posición-tiempo (arriba izq) ===== -->
              <g>
                <line x1="40" y1="140" x2="40" y2="40" stroke="#334155" stroke-width="1.6"/>
                <line x1="40" y1="140" x2="270" y2="140" stroke="#334155" stroke-width="1.6"/>
