              <text x="295" y="120" text-anchor="middle" font-size="11.5" fill="#155e75">se mide como</text>
              <text x="295" y="136" text-anchor="middle" font-size="11.5" fill="#155e75">respuesta</text>
              <text x="295" y="158" text-anchor="middle" font-size="11" fill="#0e7490" font-style="italic">eje Y</text>
