              <text x="538" y="124" font-size="10.5" fill="#b45309">30</text>
              <!-- barras de precipitación (12 meses) escala: 2 px por mm -->
              <g fill="#3b82f6">
                <rect x="80"  y="296" width="26" height="4"/>
                <rect x="118" y="294" width="26" height="6"/>
                <rect x="156" y="290" width="26" height="10"/>
                <rect x="194" y="270" width="26" height="30"/>
                <rect x="232" y="216" width="26" height="84"/>
                <rect x="270" y="208" width="26" height="92"/>
                <rect x="308" y="220" width="26" height="80"/>
                <rect x="346" y="266" width="26" height="34"/>
                <rect x="384" y="282" width="26" height="18"/>
                <rect x="422" y="290" width="26" height="10"/>
                <rect x="460" y="294" width="26" height="6"/>
                <rect x="498" y="296" width="26" height="4"/>
              </g>
              <!-- línea de temperatura (eje der, 0-30: y = 300 - C*8) -->
              <polyline fill="none" stroke="#b45309" stroke-width="3" points="93,84 131,92 169,108 207,140 245,172 283,196 321,200 359,184 397,156 435,128 473,108 511,92"/>
              <g fill="#92400e">
