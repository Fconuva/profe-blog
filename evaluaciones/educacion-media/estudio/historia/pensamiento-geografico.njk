              </g>
              <!-- leyenda -->
              <rect x="120" y="338" width="16" height="12" fill="#3b82f6"/>
              <text x="142" y="348" font-size="11.5" fill="#1e3a8a">Precipitación</text>
              <line x1="300" y1="344" x2="330" y2="344" stroke="#b45309" stroke-width="3"/>
              <circle cx="315" cy="344" r="3.5" fill="#92400e"/>
