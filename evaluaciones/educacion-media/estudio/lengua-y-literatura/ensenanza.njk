              <text x="325" y="102" fill="#334155" font-size="11" text-anchor="middle">y seleccionar</text>

              <rect x="398" y="58" width="106" height="64" rx="10" fill="#eef2ff" stroke="#4f46e5" stroke-width="2"/>
              <text x="451" y="84" fill="#3730a3" font-size="12.5" font-weight="700" text-anchor="middle">4. Organizar</text>
              <text x="451" y="102" fill="#334155" font-size="11" text-anchor="middle">la información</text>

              <rect x="335" y="158" width="170" height="64" rx="10" fill="#4f46e5" stroke="#3730a3" stroke-width="2"/>
