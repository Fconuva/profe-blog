              <text x="455" y="106" fill="#334155" font-size="11.5" text-anchor="middle">el significado</text>
              <line x1="394" y1="120" x2="516" y2="120" stroke="#c7d2fe" stroke-width="1.5"/>
              <text x="455" y="142" fill="#4f46e5" font-size="12" font-weight="700" text-anchor="middle">Metáfora</text>
              <text x="455" y="162" fill="#4f46e5" font-size="12" font-weight="700" text-anchor="middle">Metonimia</text>
              <text x="455" y="182" fill="#4f46e5" font-size="12" font-weight="700" text-anchor="middle">Sinécdoque</text>
              <text x="455" y="202" fill="#4f46e5" font-size="12" font-weight="700" text-anchor="middle">Antítesis</text>
              <text x="455" y="222" fill="#4f46e5" font-size="12" font-weight="700" text-anchor="middle">Ironía</text>
              <text x="455" y="252" fill="#64748b" font-size="10.5" font-style="italic" text-anchor="middle">trasladan o</text>
