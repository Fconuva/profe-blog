              <rect x="197" y="58" width="166" height="222" rx="12" fill="#eef2ff" stroke="#4f46e5" stroke-width="2"/>
              <text x="280" y="86" fill="#3730a3" font-size="14.5" font-weight="800" text-anchor="middle">SINTÁCTICAS</text>
