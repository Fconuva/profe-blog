              <text x="280" y="200" fill="#4f46e5" font-size="13" font-weight="700" text-anchor="middle">Hipérbaton</text>
              <text x="280" y="220" fill="#334155" font-size="11" text-anchor="middle">alterar el</text>
              <text x="280" y="236" fill="#334155" font-size="11" text-anchor="middle">orden natural</text>
