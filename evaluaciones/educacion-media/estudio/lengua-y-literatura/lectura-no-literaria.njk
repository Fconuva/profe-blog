              <text x="280" y="143" fill="#c7d2fe" font-size="9.8" text-anchor="middle">texto · imagen · sonido</text>

              <!-- Receptor: audiencia -->
              <g>
                <circle cx="452" cy="118" r="9" fill="none" stroke="#3730a3" stroke-width="2"/>
                <circle cx="432" cy="124" r="9" fill="none" stroke="#3730a3" stroke-width="2"/>
                <circle cx="472" cy="124" r="9" fill="none" stroke="#3730a3" stroke-width="2"/>
                <path d="M438 150 a14 11 0 0 1 28 0 M420 156 a13 10 0 0 1 24 0 M462 156 a13 10 0 0 1 24 0" fill="none" stroke="#3730a3" stroke-width="2" stroke-linecap="round"/>
              </g>
              <text x="452" y="178" fill="#3730a3" font-size="12" font-weight="700" text-anchor="middle">Receptor</text>

              <path d="M144 130 H216" fill="none" stroke="#4f46e5" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M344 130 H410" fill="none" stroke="#4f46e5" stroke-width="2.5" stroke-linecap="round"/>
