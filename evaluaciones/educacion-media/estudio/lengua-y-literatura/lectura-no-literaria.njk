              <text x="280" y="50" fill="#64748b" font-size="11.5" text-anchor="middle">Según su relación con las leyes de la realidad</text>
              <!-- Realista -->
              <rect x="22" y="66" width="126" height="120" rx="12" fill="#eef2ff" stroke="#4f46e5" stroke-width="2"/>
