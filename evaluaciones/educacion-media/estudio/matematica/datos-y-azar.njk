              <rect x="146" y="92" width="288" height="56" fill="#e0f2fe" stroke="#0369a1" stroke-width="2.5"/>
              <!-- mediana Q2 -->
              <line x1="290" y1="92" x2="290" y2="148" stroke="#dc2626" stroke-width="3"/>
              <!-- bigote der Q3->max -->
              <line x1="434" y1="120" x2="520" y2="120" stroke="#075985" stroke-width="2.5"/>
              <line x1="520" y1="104" x2="520" y2="136" stroke="#075985" stroke-width="2.5"/>
              <!-- etiquetas -->
              <g font-size="12.5" text-anchor="middle">
                <text x="60" y="172" fill="#334155">mín</text><text x="60" y="190" fill="#0f172a" font-weight="700">4</text>
                <text x="146" y="172" fill="#0369a1" font-weight="700">Q₁</text><text x="146" y="190" fill="#0f172a" font-weight="700">7</text>
                <text x="290" y="172" fill="#dc2626" font-weight="700">Q₂ (mediana)</text><text x="290" y="190" fill="#0f172a" font-weight="700">12</text>
