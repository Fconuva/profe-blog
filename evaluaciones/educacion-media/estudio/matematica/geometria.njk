              <path d="M 122 240 A 42 42 0 0 0 113 213" fill="none" stroke="#dc2626" stroke-width="2.5"/>
              <text x="138" y="228" text-anchor="middle" font-size="17" fill="#dc2626" font-weight="700">&#945;</text>
              <!-- rótulos de lados -->
              <text x="250" y="170" text-anchor="middle" font-size="15" fill="#075985" font-weight="700">hipotenusa</text>
              <text x="470" y="155" text-anchor="middle" font-size="14" fill="#16a34a" font-weight="700" transform="rotate(90 470 155)">cateto opuesto</text>
              <text x="260" y="262" text-anchor="middle" font-size="14" fill="#9333ea" font-weight="700">cateto adyacente</text>
