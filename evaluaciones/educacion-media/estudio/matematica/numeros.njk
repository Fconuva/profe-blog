              <text x="171" y="174" text-anchor="middle" font-size="11.5" fill="#1e40af" font-style="italic">finito o periódico</text>
              <!-- Enteros Z -->
              <rect x="76" y="186" width="190" height="112" rx="10" fill="#bfdbfe" stroke="#1d4ed8" stroke-width="2"/>
