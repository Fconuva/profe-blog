              <text x="104" y="104" text-anchor="middle" font-size="11.5" fill="#9a3412" font-style="italic">la que cambio</text>
              <text x="104" y="138" text-anchor="middle" font-size="14" font-weight="700" fill="#7c2d12">Temperatura</text>
              <text x="104" y="164" text-anchor="middle" font-size="11.5" fill="#9a3412">10, 20, 30, 40 &deg;C</text>
              <text x="104" y="190" text-anchor="middle" font-size="11.5" fill="#9a3412">(eje x)</text>
              <!-- flecha -->
              <line x1="190" y1="131" x2="226" y2="131" stroke="#334155" stroke-width="2" marker-end="url(#fr-vflecha)"/>
