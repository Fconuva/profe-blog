              </defs>
              <text x="280" y="26" text-anchor="middle" font-size="18" font-weight="700" fill="#0f172a">La escritura emergente progresa por etapas</text>
              <!-- línea base -->
              <path d="M28,140 L520,140" fill="none" stroke="#9d174e" stroke-width="2" stroke-linecap="round" marker-end="url(#emg-ar)"/>
              <!-- 4 hitos con caja-muestra arriba y etiqueta abajo -->
