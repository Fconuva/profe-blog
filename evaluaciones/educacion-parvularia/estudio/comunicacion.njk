              <text x="227" y="166" text-anchor="middle" font-size="13" font-weight="700" fill="#9d174e">Pseudoletras</text>
              <!-- 3 su nombre -->
              <circle cx="374" cy="140" r="6" fill="#be185d"/>
              <rect x="330" y="66" width="88" height="50" rx="8" fill="#fff" stroke="#cbd5e1" stroke-width="2"/>
              <text x="374" y="100" text-anchor="middle" font-size="20" font-weight="700" fill="#334155" letter-spacing="2">ANA</text>
              <text x="374" y="166" text-anchor="middle" font-size="13" font-weight="700" fill="#9d174e">Su nombre</text>
              <text x="374" y="183" text-anchor="middle" font-size="11.5" fill="#334155">y letras</text>
