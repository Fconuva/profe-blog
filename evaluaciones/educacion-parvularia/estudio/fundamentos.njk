                  <path d="M1 1 L8 4.5 L1 8" fill="none" stroke="#be185d" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </marker>
              </defs>
              <!-- conectores verticales -->
              <g stroke="#cbd5e1" stroke-width="2" fill="none">
                <path d="M280 64 L280 96" marker-end="url(#arrParv)"/>
                <path d="M280 150 L280 182" marker-end="url(#arrParv)"/>
                <path d="M280 236 L280 268" marker-end="url(#arrParv)"/>
                <path d="M280 322 L280 354" marker-end="url(#arrParv)"/>
              </g>
              <g text-anchor="middle">
                <!-- nivel 0: BCEP -->
                <rect x="210" y="20" width="140" height="44" rx="11" fill="#be185d"/>
                <text x="280" y="48" font-size="17" font-weight="800" fill="#fff">BCEP</text>
