                <rect x="186" y="100" width="188" height="50" rx="11" fill="#fce7f3" stroke="#be185d" stroke-width="2"/>
                <text x="280" y="122" font-size="14.5" font-weight="700" fill="#9d174e">3 Ámbitos de experiencia</text>
                <text x="280" y="140" font-size="11.5" fill="#334155">p. ej. Comunicación Integral</text>
