              <text x="280" y="218" text-anchor="middle" font-size="13" font-weight="800" fill="#fff">para el</text>
              <text x="280" y="236" text-anchor="middle" font-size="13" font-weight="800" fill="#fff">aprendizaje</text>
              <g text-anchor="middle">
                <!-- arriba-izq: Planificación y evaluación -->
