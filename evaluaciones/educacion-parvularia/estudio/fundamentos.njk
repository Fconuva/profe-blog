                <text x="280" y="398" font-size="11.5" fill="#64748b">1.º 0–3 años · 2.º 3–6 años</text>
              </g>
              <!-- rama lateral: OAT -->
              <path d="M382 297 L470 297" fill="none" stroke="#be185d" stroke-width="2" stroke-dasharray="5 4" marker-end="url(#arrParv)"/>
