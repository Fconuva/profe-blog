              <text x="290" y="30" fill="#0f172a" font-size="17" font-weight="700" text-anchor="middle">Alfabetización emocional: tres pasos</text>

              <!-- 3 pasos en fila -->
              <rect class="emb" x="26" y="60" width="160" height="86" rx="12"/>
