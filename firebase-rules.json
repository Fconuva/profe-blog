{
  "rules": {
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": [
        "username",
        "email"
      ],
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "role": {
          ".validate": "newData.val() === 'cliente' || root.child('users').child(auth.uid).child('role').val() === 'admin'"
        }
      }
    },
    "portafolios": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "paymentStatus": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'admin' || newData.val() === 'pre-inscrito' || newData.val() === 'pendiente' || newData.val() === 'pendiente_verificacion'"
        },
        "paymentAmount": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "esAbono": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "esRegalo": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "saldoPendiente": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "paidAt": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "paymentVerifiedAt": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() === 'admin'"
        }
      }
    },
    "verified_payments": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": false,
      ".indexOn": [
        "email",
        "paymentId",
        "uid"
      ]
    },
    "courses": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": [
        "userId",
        "courseName",
        "period"
      ]
    },
    "counters": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "logs": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null",
      ".indexOn": [
        "timestamp",
        "userId",
        "action"
      ]
    },
    "plataforma_estudiantes": {
      "admins": {
        ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        "$uid": {
          ".read": "auth != null && auth.uid === $uid"
        }
      },
      "docentes": {
        ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        "$uid": {
          ".read": "auth != null && auth.uid === $uid"
        }
      },
      "estudiantes": {
        ".read": "auth != null",
        ".indexOn": [
          "curso"
        ],
        "$uid": {
          ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)"
        }
      },
      "sesiones": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
      },
      "respuestas": {
        ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        "$sesionId": {
          ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)",
            ".validate": "root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || data.child('completada').val() !== true || newData.child('completada').val() === true"
          }
        }
      },
      "resultados": {
        ".read": "auth != null",
        "$sesionId": {
          ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
          "$uid": {
            ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)"
          }
        }
      },
      "ranking": {
        ".read": "auth != null",
        "$sesionId": {
          ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
          "$curso": {
            "$uid": {
              ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)"
            }
          }
        }
      },
      "avatar": {
        ".read": "auth != null",
        "$uid": {
          ".read": "auth != null",
          ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)"
        }
      },
      "tareas": {
        ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        "$tareaId": {
          ".indexOn": [
            "curso",
            "completada",
            "submitted_at",
            "last_save"
          ],
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)"
          }
        }
      },
      "mensajes": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
      },
      "admin_refresh": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        "all": {
          ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
        },
        "cursos": {
          "$curso": {
            ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
          }
        },
        "estudiantes": {
          "$uid": {
            ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
          }
        }
      },
      "arena": {
        "history": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "daily": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "records": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },
    "plataforma_lecturas": {
      ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
      "admins": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid"
        }
      },
      "sesiones": {
        "$sesionId": {
          ".read": "auth != null && root.child('plataforma_lecturas/asignaciones').child(auth.uid).child($sesionId).val() === true"
        }
      },
      "asignaciones": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid"
        }
      },
      "respuestas": {
        "$sesionId": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid && root.child('plataforma_lecturas/asignaciones').child(auth.uid).child($sesionId).val() === true"
          }
        }
      },
      "resultados": {
        "$sesionId": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid && root.child('plataforma_lecturas/sesiones').child($sesionId).child('resultados_visibles').val() === true",
            ".write": "auth != null && auth.uid === $uid && root.child('plataforma_lecturas/asignaciones').child(auth.uid).child($sesionId).val() === true"
          }
        }
      }
    },
    "plataforma_np": {
      "access": {
        ".read": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true",
        "allowedUids": {
          "$uid": {
            ".read": "auth != null && (auth.uid === $uid || root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true)",
            ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
          }
        }
      },
      "$unitId": {
        ".read": "auth != null && (root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_np/access/allowedUids').child(auth.uid).val() === true)",
        "records": {
          ".write": "auth != null && (root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_np/access/allowedUids').child(auth.uid).val() === true)",
          "$recordId": {
            ".write": "auth != null && (root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true || root.child('plataforma_np/access/allowedUids').child(auth.uid).val() === true)"
          }
        },
        "config": {
          ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
        },
        "importMeta": {
          ".write": "auth != null && root.child('plataforma_estudiantes/admins').child(auth.uid).val() === true"
        }
      }
    },
    "blacklist": {
      "emails": {
        "$email_key": {
          ".read": "true",
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        }
      },
      "telefonos": {
        "$phone_key": {
          ".read": "true",
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        }
      }
    },
    "archived_users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    ".read": false,
    ".write": false,
    "ecep_usuarios": {
      ".read": "auth != null && auth.token.email === 'fconuva@gmail.com'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.email === 'fconuva@gmail.com')",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "ecep_accesos": {
      ".read": "auth != null && auth.token.email === 'fconuva@gmail.com'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.email === 'fconuva@gmail.com')",
        ".write": "auth != null && auth.token.email === 'fconuva@gmail.com'"
      }
    }
  }
}