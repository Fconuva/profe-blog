<script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/ScrollTrigger.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/SplitText.min.js" defer></script>
<script defer>
document.addEventListener('DOMContentLoaded', function () {

  /* ---------- FAQ (siempre, sin GSAP) ---------- */
  document.querySelectorAll('.faq-toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var answer = this.nextElementSibling, icon = this.querySelector('.faq-icon');
      var isOpen = answer.classList.contains('open');
      document.querySelectorAll('.faq-answer').forEach(function (a) { a.classList.remove('open'); });
      document.querySelectorAll('.faq-icon').forEach(function (i) { i.style.transform = ''; });
      if (!isOpen) { answer.classList.add('open'); icon.style.transform = 'rotate(180deg)'; }
    });
  });

  /* ---------- Barra de progreso (siempre) ---------- */
  var _sp = document.getElementById('scroll-progress');
  function _prog() {
    var h = document.documentElement.scrollHeight - window.innerHeight;
    if (_sp) _sp.style.width = (h > 0 ? Math.min(100, Math.max(0, window.scrollY / h * 100)) : 0) + '%';
  }
  window.addEventListener('scroll', _prog, { passive: true });
  window.addEventListener('resize', _prog);
  _prog();

  if (!window.gsap || !window.ScrollTrigger) return;
  gsap.registerPlugin(ScrollTrigger, SplitText);

  var mm = gsap.matchMedia();

  /* ============ SOLO con movimiento permitido ============ */
  mm.add('(prefers-reduced-motion: no-preference)', function () {

    /* ---- Hero: entrada ---- */
    var heroTitle = document.getElementById('hero-title');
    document.fonts.ready.then(function () {
      var split = null;
      try { split = new SplitText(heroTitle, { type: 'words,chars' }); } catch (e) {}
      var tl = gsap.timeline({ defaults: { ease: 'expo.out' } });
      if (split) tl.from(split.chars, { yPercent: 110, opacity: 0, duration: 1, stagger: 0.02 }, 0.1);
      tl.from('.hero-in', { y: 26, opacity: 0, duration: 0.8, stagger: 0.12 }, 0.25)
        .from('#hero-video', { y: 60, opacity: 0, scale: 0.94, duration: 1 }, 0.45);
      ScrollTrigger.refresh();
    });

    /* Hero: parallax al hacer scroll */
    gsap.to('#hero-video', {
      y: -40, ease: 'none',
      scrollTrigger: { trigger: '#inicio', start: 'top top', end: 'bottom top', scrub: true }
    });
    gsap.to('.sm-orb', {
      y: 80, ease: 'none',
      scrollTrigger: { trigger: '#inicio', start: 'top top', end: 'bottom top', scrub: true }
    });

    /* ---- Marquee infinito ---- */
    gsap.to('#marquee-track', { xPercent: -50, ease: 'none', duration: 26, repeat: -1 });

    /* ---- Manifiesto: palabras que se encienden (pinned) ---- */
    document.fonts.ready.then(function () {
    var maniWords = [];
    document.querySelectorAll('.mani-l').forEach(function (line) {
      try {
        var s = new SplitText(line, { type: 'words', wordsClass: 'w' });
        maniWords = maniWords.concat(s.words);
      } catch (e) {}
    });
    if (maniWords.length) {
      gsap.set(maniWords, { opacity: 0.13 });
      var maniTl = gsap.timeline({
        scrollTrigger: {
          trigger: '#manifiesto', start: 'top top', end: '+=2200',
          pin: '.mani-pin', scrub: 0.6, anticipatePin: 1
        }
      });
      maniTl.to(maniWords, { opacity: 1, stagger: 0.55, ease: 'none' }, 0)
            .fromTo('#mani-figure',
              { clipPath: 'inset(18% 10% 18% 10% round 24px)', scale: 0.94, opacity: 0.4 },
              { clipPath: 'inset(0% 0% 0% 0% round 24px)', scale: 1, opacity: 1, ease: 'none', duration: maniWords.length * 0.22 },
              '>-2');
    }
    ScrollTrigger.refresh();
    });

    /* ---- Credencial ---- */
    gsap.from('.cred-copy', { x: -48, opacity: 0, duration: 0.9, ease: 'expo.out',
      scrollTrigger: { trigger: '#por-que-confiar', start: 'top 70%' } });
    gsap.from('.cred-img', { x: 48, opacity: 0, duration: 0.9, ease: 'expo.out',
      scrollTrigger: { trigger: '#por-que-confiar', start: 'top 70%' } });

    /* ---- Módulos: horizontal SOLO en pantallas grandes ---- */
    mm.add('(min-width: 1024px)', function () {
      var track = document.getElementById('mod-track');
      var panels = gsap.utils.toArray('.sm-panel');
      if (track && panels.length > 1) {
        gsap.to(track, {
          /* el track mide panels×100vw: para llegar al último panel se desplaza (n-1)/n de su ancho */
          xPercent: -100 * (panels.length - 1) / panels.length,
          ease: 'none',
          scrollTrigger: {
            trigger: '#modulos', start: 'top top',
            end: function () { return '+=' + (window.innerWidth * (panels.length - 1)); },
            pin: true, scrub: 1, invalidateOnRefresh: true, anticipatePin: 1
          }
        });
      }
      return function () {};
    });

    /* Módulos en móvil: reveal simple */
    mm.add('(max-width: 1023px)', function () {
      gsap.utils.toArray('.sm-panel').forEach(function (p) {
        gsap.from(p, { y: 40, opacity: 0, duration: 0.7, ease: 'expo.out',
          scrollTrigger: { trigger: p, start: 'top 78%' } });
      });
      return function () {};
    });

    /* ---- Contadores ---- */
    gsap.utils.toArray('.count').forEach(function (el) {
      var to = parseInt(el.dataset.to || '0', 10);
      ScrollTrigger.create({
        trigger: el, start: 'top 85%', once: true,
        onEnter: function () {
          gsap.fromTo(el, { innerText: 0 }, {
            innerText: to, duration: 1.4, ease: 'power2.out',
            snap: { innerText: 1 },
            onUpdate: function () { el.innerText = Math.round(parseFloat(el.innerText)); }
          });
        }
      });
    });

    /* ---- Stack de pasos: leve profundidad ---- */
    gsap.utils.toArray('.sm-step').forEach(function (card, i, arr) {
      if (i === arr.length - 1) return;
      gsap.to(card, {
        scale: 0.965, filter: 'brightness(.97)', transformOrigin: 'center top', ease: 'none',
        scrollTrigger: { trigger: arr[i + 1], start: 'top bottom', end: 'top 40%', scrub: true }
      });
    });

    /* ---- 14 agentes: batch ---- */
    var showBatch = function (els) { gsap.to(els, { y: 0, opacity: 1, duration: 0.55, stagger: 0.06, ease: 'expo.out', overwrite: true }); };
    gsap.set('.agent', { y: 22, opacity: 0 });
    ScrollTrigger.batch('.agent', { start: 'top 88%', onEnter: showBatch, onEnterBack: showBatch });

    /* ---- Reveals genéricos ---- */
    gsap.utils.toArray('.rise').forEach(function (el) {
      gsap.from(el, { y: 36, opacity: 0, duration: 0.8, ease: 'expo.out',
        scrollTrigger: { trigger: el, start: 'top 82%' } });
    });
    gsap.set('.price', { y: 30, opacity: 0 });
    ScrollTrigger.batch('.price', { start: 'top 86%', onEnter: showBatch, onEnterBack: showBatch });
    gsap.set('.stepq', { y: 26, opacity: 0 });
    ScrollTrigger.batch('.stepq', { start: 'top 86%', onEnter: showBatch, onEnterBack: showBatch });

    /* ---- Testimonios: doble marquee ---- */
    var ta = gsap.to('.ttrack-a', { xPercent: -50, ease: 'none', duration: 55, repeat: -1 });
    var tb = gsap.fromTo('.ttrack-b', { xPercent: -50 }, { xPercent: 0, ease: 'none', duration: 55, repeat: -1 });
    document.querySelectorAll('.sm-trow').forEach(function (row) {
      row.addEventListener('mouseenter', function () { gsap.to([ta, tb], { timeScale: 0.15, duration: 0.4 }); });
      row.addEventListener('mouseleave', function () { gsap.to([ta, tb], { timeScale: 1, duration: 0.4 }); });
    });

    /* ---- CTA final: título ---- */
    document.fonts.ready.then(function () {
      var cta = document.getElementById('cta-title');
      try {
        var s2 = new SplitText(cta, { type: 'chars' });
        gsap.from(s2.chars, {
          yPercent: 120, opacity: 0, stagger: 0.03, duration: 0.9, ease: 'expo.out',
          scrollTrigger: { trigger: cta, start: 'top 80%' }
        });
      } catch (e) {}
    });

    return function () {}; /* cleanup lo maneja matchMedia */
