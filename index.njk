              <span>${item.year}</span>
            </div>
          </div>
        `).join('');

        // Render mini indicator bars or dots (just 5 active dots max, or simple bars to avoid overflow)
        stepsContainer.innerHTML = testimonials.map((_, idx) => `
          <button class="indicator-dot w-2.5 h-1 rounded-full bg-slate-200 transition-all ${idx === 0 ? 'bg-emerald-600 w-5' : ''}" data-slide="${idx}" aria-label="Slide ${idx + 1}"></button>
        `).join('');

        const dots = document.querySelectorAll('.indicator-dot');

        function updateSlide(index) {
          currentSlide = (index + totalSlides) % totalSlides;
          if (track) {
            track.style.transform = `translateX(-${currentSlide * 100}%)`;
          }
          if (counterEl) {
            counterEl.textContent = `${currentSlide + 1} de ${totalSlides} colegas`;
          }
          dots.forEach((dot, idx) => {
            if (idx === currentSlide) {
              dot.classList.remove('bg-slate-200', 'w-2.5');
              dot.classList.add('bg-emerald-600', 'w-5');
            } else {
              dot.classList.remove('bg-emerald-600', 'w-5');
              dot.classList.add('bg-slate-200', 'w-2.5');
            }
          });

          // Optional: Scroll dots container of indicators to keep the active one visible if needed
          const activeDot = dots[currentSlide];
          if (activeDot && stepsContainer) {
            stepsContainer.scrollTo({
              left: activeDot.offsetLeft - stepsContainer.clientWidth / 2 + activeDot.clientWidth / 2,
              behavior: 'smooth'
            });
          }
        }

        if (prevBtn) prevBtn.addEventListener('click', () => updateSlide(currentSlide - 1));
        if (nextBtn) nextBtn.addEventListener('click', () => updateSlide(currentSlide + 1));
        dots.forEach((dot, idx) => {
          dot.addEventListener('click', () => updateSlide(idx));
        });
