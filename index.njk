---
layout: layout.njk
title: Inicio
---

<!-- Barra de progreso de lectura -->
<div id="scroll-progress" class="fixed top-0 left-0 h-1 bg-accent-400 z-[100]" style="width:0%"></div>

<style>
  /* ============ HOME 2026 · scrollmove ============ */
  :root{
    --sm-navy:#0b1226; --sm-navy2:#101b3a; --sm-ink:#0f172a;
    --sm-indigo:#6366f1; --sm-teal:#5eead4; --sm-teal-deep:#0d9488;
    --sm-mist:#c7d2fe;
  }
  .sm-dark{background:
      radial-gradient(1100px 520px at 85% -10%, rgba(99,102,241,.28), transparent 60%),
      radial-gradient(900px 480px at 0% 110%, rgba(13,148,136,.20), transparent 55%),
      linear-gradient(180deg, var(--sm-navy) 0%, var(--sm-navy2) 100%);}
  .sm-display{font-family:'Poppins',system-ui,sans-serif;font-weight:800;letter-spacing:-.03em;line-height:1.04;text-wrap:balance}
  .sm-num-ghost{font-family:'Poppins',sans-serif;font-weight:800;line-height:1;color:transparent;-webkit-text-stroke:1.5px rgba(255,255,255,.16)}

  /* Marquee */
  .sm-marquee{overflow:hidden;white-space:nowrap;-webkit-mask-image:linear-gradient(90deg,transparent,#000 8%,#000 92%,transparent);mask-image:linear-gradient(90deg,transparent,#000 8%,#000 92%,transparent)}
  .sm-marquee .track{display:inline-flex;align-items:center;gap:2.5rem;padding-right:2.5rem;will-change:transform}
  .sm-marquee .item{display:inline-flex;align-items:center;gap:2.5rem;font-family:'Poppins',sans-serif;font-weight:700;font-size:clamp(.95rem,1.6vw,1.15rem);color:#96a3c7}
  .sm-marquee .item .star{color:var(--sm-teal);font-size:.8em}

  /* Manifiesto: palabras que se encienden */
  .sm-mani-line{font-family:'Poppins',sans-serif;font-weight:800;letter-spacing:-.03em;line-height:1.12;font-size:clamp(1.7rem,4.6vw,3.6rem);color:#fff;text-wrap:balance}
  .sm-mani-line .w{display:inline-block}

  /* Módulos horizontales */
  .sm-hwrap{overflow:hidden}
  .sm-htrack{display:flex;will-change:transform}
  .sm-panel{flex:0 0 100vw;min-height:100vh;display:flex;align-items:center}
  .sm-panel-img{border-radius:1.5rem;box-shadow:0 40px 90px -40px rgba(0,0,0,.75);outline:1px solid rgba(255,255,255,.1)}
  @media (max-width:1023px){ .sm-htrack{display:block} .sm-panel{flex:none;min-height:0} }

  /* Stack de pasos (sticky) */
  .sm-step{position:sticky;top:96px}
  .sm-step:nth-child(2){top:110px}.sm-step:nth-child(3){top:124px}.sm-step:nth-child(4){top:138px}

  /* Testimonios marquee */
  .sm-trow{overflow:hidden;-webkit-mask-image:linear-gradient(90deg,transparent,#000 6%,#000 94%,transparent);mask-image:linear-gradient(90deg,transparent,#000 6%,#000 94%,transparent)}
  .sm-ttrack{display:flex;gap:1.25rem;width:max-content;will-change:transform;padding:.25rem 0}
  .sm-tcard{width:min(86vw,380px);flex:none;background:#fff;border:1px solid #e5e7eb;border-radius:1.25rem;padding:1.25rem 1.35rem;box-shadow:0 10px 30px -18px rgba(15,23,42,.18)}

  /* FAQ */
  .faq-answer{max-height:0;overflow:hidden;transition:max-height .35s cubic-bezier(.22,1,.36,1)}
  .faq-answer.open{max-height:400px}

  /* Reduced motion: todo visible y quieto */
  @media (prefers-reduced-motion:reduce){
    .sm-marquee .track,.sm-ttrack{transform:none!important;animation:none!important}
  }
</style>

