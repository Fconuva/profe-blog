<!-- Barra de progreso de lectura -->
<div id="scroll-progress" class="fixed top-0 left-0 h-1 bg-accent-400 z-[100]" style="width:0%"></div>

<style>
  /* ===== Reveals al entrar en viewport (ease-out fuerte, breve) ===== */
  .reveal{opacity:0;transform:translateY(28px);transition:opacity .5s cubic-bezier(.16,1,.3,1), transform .5s cubic-bezier(.16,1,.3,1);}
  .reveal.visible{opacity:1;transform:none;}
  .reveal-left{opacity:0;transform:translateX(-40px);transition:opacity .5s cubic-bezier(.16,1,.3,1), transform .5s cubic-bezier(.16,1,.3,1);}
  .reveal-left.visible{opacity:1;transform:none;}
  .reveal-right{opacity:0;transform:translateX(40px);transition:opacity .5s cubic-bezier(.16,1,.3,1), transform .5s cubic-bezier(.16,1,.3,1);}
  .reveal-right.visible{opacity:1;transform:none;}

  /* Cascada corta: cada hijo entra en secuencia */
  .reveal-group > *{opacity:0;transform:translateY(22px) scale(.98);transition:opacity .5s cubic-bezier(.16,1,.3,1), transform .5s cubic-bezier(.16,1,.3,1);}
  .reveal-group.visible > *{opacity:1;transform:none;}
  .reveal-group.visible > *:nth-child(1){transition-delay:.04s}
  .reveal-group.visible > *:nth-child(2){transition-delay:.08s}
  .reveal-group.visible > *:nth-child(3){transition-delay:.12s}
  .reveal-group.visible > *:nth-child(4){transition-delay:.16s}
  .reveal-group.visible > *:nth-child(5){transition-delay:.20s}
  .reveal-group.visible > *:nth-child(6){transition-delay:.24s}
  .reveal-group.visible > *:nth-child(7){transition-delay:.28s}
  .reveal-group.visible > *:nth-child(8){transition-delay:.32s}
  .reveal-group.visible > *:nth-child(n+9){transition-delay:.36s}

  /* ===== Entrada del hero al cargar: escalonada, ease-out fuerte ===== */
  /* relleno 'both' → el estado final (visible) queda fijo; si la animación no corre, el contenido NO desaparece */
  @keyframes heroUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
  @keyframes certIn{from{opacity:0;transform:translateX(28px)}to{opacity:1;transform:translateX(0)}}
  @keyframes certFloat{0%,100%{transform:translateY(0) rotate(2deg)}50%{transform:translateY(-12px) rotate(2deg)}}
  .hero-anim>*{animation:heroUp .7s cubic-bezier(.16,1,.3,1) both}
  .hero-anim>*:nth-child(1){animation-delay:.06s}
  .hero-anim>*:nth-child(2){animation-delay:.14s}
  .hero-anim>*:nth-child(3){animation-delay:.22s}
  .hero-anim>*:nth-child(4){animation-delay:.30s}
  .hero-anim>*:nth-child(5){animation-delay:.38s}
  .hero-anim>*:nth-child(6){animation-delay:.46s}
  .cert-figure{animation:certIn .9s cubic-bezier(.16,1,.3,1) .2s both}
  .cert-float{animation:certFloat 6s ease-in-out 1.1s infinite;will-change:transform}

  @media (prefers-reduced-motion:reduce){
    .reveal,.reveal-left,.reveal-right,.reveal-group>*{transition:none;opacity:1;transform:none;}
    .hero-anim>*,.cert-figure{animation:none}
    .cert-float{animation:none}}
</style>

